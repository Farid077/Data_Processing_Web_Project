@model UserUpdateVM

@{
    ViewData["Title"] = "Edit User";
    ViewData["ActivePage"] = "Users";
}

<div class="topbar">
    <div class="breadcrumb">
        <a asp-action="Index" asp-controller="Home">Panel</a>
        <span class="sep">/</span>
        <a asp-action="Index">İstifadəçilər</a>
        <span class="sep">/</span>
        <span class="current">İstifadəçini Redaktə Et</span>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-icon blue">✎</div>
        <div>
            <div class="card-title">İstifadəçini Redaktə Et</div>
            <div class="card-sub">Bu hesabın məlumatlarını redaktə edin.</div>
        </div>
    </div>

    <div class="avatar-row">
        <div class="big-avatar">
            @ViewData["Id"]?.ToString()?.ToUpper()[0]@ViewData["Id"]?.ToString()?.ToUpper()[1]
        </div>
        <div class="avatar-meta">
            <strong>@ViewData["Id"]?.ToString()</strong>
        </div>
    </div>

    <form asp-action="Update" asp-controller="Users" method="post" asp-route-id="@ViewData["Id"]?.ToString()">
        @Html.AntiForgeryToken()
        <div class="form-body">
            <div class="form-row single">
                <div class="field">
                    <label asp-for="Role">Rol</label>
                    <select asp-for="Role" id="role">
                        <option value="">Rol seçin...</option>
                        @foreach (var role in Model.RoleOptions)
                        {
                            <option selected="@(role == Model.Role ? role : null)" value="@role">@role</option>
                        }
                    </select>
                    <span asp-validation-for="Role" class="err-msg"></span>
                </div>
            </div>

            <div class="form-row single">
                <div class="field">
                    <label asp-for="Password">
                        Yeni Şifrə <span style="color:var(--muted);font-size:10px;">(dəyişməmək üçün boş saxlayın)</span>
                    </label>
                    <input asp-for="Password" name="Password" type="password" id="password" placeholder="Dəyişməmək üçün xananı boş saxlayın">
                    <span class="input-icon toggle-pw" id="pw-toggle" onclick="togglePw()">◷ şifrəni göstər</span>
                    <span asp-validation-for="Password" class="err-msg"></span>
                </div>
            </div>

            <div class="form-row single">
                <div class="field">
                    <label asp-for="ConfirmPassword">Şifrəni Təsdiqlə</label>
                    <input asp-for="ConfirmPassword" name="ConfirmPassword" type="password" id="confirmpassword" placeholder="Şifrəni Təsdiqləyin">
                    <span class="input-icon toggle-pw" id="pw-toggle-confirm" onclick="togglePwConfirm()">◷ show password</span>
                    <span asp-validation-for="ConfirmPassword" class="err-msg"></span>
                </div>
            </div>
        </div>

        <div class="card-footer">
            <div class="footer-right">
                @if (User.HasAccess(Pages.Users, PageAccess.Update)){
                    <button type="submit" class="btn-save">Dəyişiklikləri Yadda Saxla</button>
                }
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function togglePw() {
            const input = document.getElementById('password');
            const icon  = document.getElementById('pw-toggle');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.textContent = input.type === 'password' ? '◷ şifrəni göstər' : '◉ şifrəni gizlət';
        }

        function togglePwConfirm() {
            const input = document.getElementById('confirmpassword');
            const icon  = document.getElementById('pw-toggle-confirm');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.textContent = input.type === 'password' ? '◷ şifrəni göstər' : '◉ şifrəni gizlət';
        }
    </script>
}
