@model UserCreateVM

@{
    ViewData["Title"] = "Add User";
    ViewData["ActivePage"] = "Users";
}

<div class="topbar">
    <div class="breadcrumb">
        <a asp-action="Index" asp-controller="Home">Panel</a>
        <span class="sep">/</span>
        <a asp-action="Index">İstifadəçilər</a>
        <span class="sep">/</span>
        <span class="current">İstifadəçi Əlavə Et</span>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-icon">◈</div>
        <div>
            <div class="card-title">Yeni İstifadəçi Əlavə Et</div>
            <div class="card-sub">Yeni istifadəçi yaratmaq üçün məlumatları doldurun.</div>
        </div>
    </div>

    <form method="post" asp-action="Create" class="form-body">
        @Html.AntiForgeryToken()
        <div class="form-row single">
            <div class="field">
                <label asp-for="Username">İstifadəçi adı</label>
                <input asp-for="Username" type="text" name="Username" placeholder="məs. Elnur">
                <span asp-validation-for="Username" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field">
                <label asp-for="Role">Rol</label>
                <select asp-for="Role" id="role">
                    <option value="">Rol seçin...</option>
                    @foreach (var role in Model.RoleOptions)
                    {
                        <option selected="@(role == Model.Role ? role : null)" value="@role">@role</option>
                    }
                </select>
                <span asp-validation-for="Role" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field">
                <label asp-for="Password">Şifrə</label>
                <input asp-for="Password" name="Password" type="password" id="password" placeholder="Min. 8 simvol">
                <span class="input-icon toggle-pw" id="pw-toggle" onclick="togglePw()">◷ şifrəni göstər</span>
                <span asp-validation-for="Password" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field">
                <label asp-for="ConfirmPassword">Şifrəni Təsdiqlə</label>
                <input asp-for="ConfirmPassword" name="ConfirmPassword" type="password" id="confirmpassword" placeholder="Şifrəni təsdiqləyin">
                <span class="input-icon toggle-pw" id="pw-toggle-confirm" onclick="togglePwConfirm()">◷ şifrəni göstər</span>
                <span asp-validation-for="ConfirmPassword" class="err-msg"></span>
            </div>
        </div>
        @if (User.HasAccess(Pages.Users, PageAccess.Create)){
            <button type="submit" class="btn-save">İstifadəçi Yarat</button>
        }
    </form>
</div>

@section Scripts {
    <script>
        function togglePw() {
            const input = document.getElementById('password');
            const icon  = document.getElementById('pw-toggle');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.textContent = input.type === 'password' ? '◷ şifrəni göstər' : '◉ şifrəni gizlət';
        }

        function togglePwConfirm() {
            const input = document.getElementById('confirmpassword');
            const icon  = document.getElementById('pw-toggle-confirm');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.textContent = input.type === 'password' ? '◷ şifrəni göstər' : '◉ şifrəni gizlət';
        }
    </script>
}
