@model List<UserManagementVM>

@{
    ViewData["Title"] = "Users";
    ViewData["ActivePage"] = "Users";
}

<!-- ── DELETE CONFIRMATION OVERLAY ── -->
<div class="overlay" id="deleteOverlay" onclick="closeDelete(event)">
    <div class="dialog">
        <div class="dialog-icon">⚠</div>
        <h3>Bu istifadəçini silmək istəyirsiniz?</h3>
        <p>Bu, <strong id="deleteTargetName"></strong> sistemdən tamamilə siləcək. Bu əməliyyat geri qaytarıla bilməz.</p>
        <div class="dialog-btns">
            <button class="btn-cancel" onclick="closeDelete()">Ləğv et</button>
            <form id="deleteForm" method="POST">
                @Html.AntiForgeryToken()
                @if (User.HasAccess(Pages.Users, PageAccess.Delete)){
                    <button type="submit" class="btn-confirm-delete">Bəli, sil</button>
                }
            </form>
        </div>
    </div>
</div>

@* <div class="topbar">
    <div class="page-title">Users</div>
</div> *@

@* <div class="stats-grid">
    <div class="stat-card" style="--accent-color: var(--accent)">
        <div class="stat-icon">◈</div>
        <div class="stat-label">Total Users</div>
        <div class="stat-value">@Model.Count()</div>
    </div>
</div> *@

<div class="section-header">
    <div class="section-title">İstifadəçilərin İdarə Edilməsi</div>
    <div style="display: flex;">
        <div class="stat-label">Ümumi İstifadəçi Sayı:</div>
        <div style="margin-left: 15px;" class="stat-label">@Model.Count()</div>
    </div>
    @if (User.HasAccess(Pages.Users, PageAccess.Create))
    {
        <a style="text-decoration:none" asp-action="Create" class="btn-accent">+ Yeni İstifadəçi</a>
    }
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>İstifadəçi Adı</th>
                <th>Rol</th>
                <th>Status</th>
                <th>Qoşulma tarixi</th>
                <th>Əməliyyatlar</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <div class="cell-user">
                            <div class="mini-avatar" style="background:rgba(200,255,62,.15);color:var(--accent)">
                                @user.Username.ToUpper()[0]@user.Username.ToUpper()[1]
                            </div>
                            <div>
                                <div class="cell-name">@user.Username</div>
                            </div>
                        </div>
                    </td>
                    <td><span class="role-tag">@user.Role</span></td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="status-pill s-active">Aktiv</span>
                        }
                        else
                        {
                            <span class="status-pill s-inactive">Qeyri-aktiv</span>
                        }
                    </td>
                    <td>@user.CreatedTime</td>
                    <td style="display:flex;">
                        @if (user.Role != "SuperAdmin")
                        {
                            @if (User.HasAccess(Pages.Users, PageAccess.Update))
                            {
                                <a asp-action="Update" asp-route-id="@user.Username" class="action-btn edit" style="text-decoration:none;">Redaktə et</a>
                            }

                            @if (User.HasAccess(Pages.Users, PageAccess.Delete))
                            {
                                <form method="POST" class="action">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Username" />
                                    <button class="action-btn del" type="button" onclick="openDelete('@user.Username', 'Users/Delete/@user.Username')">
                                        Sil
                                    </button>
                                    @if (user.IsActive)
                                    {
                                        <button class="action-btn revoke" type="submit" formaction="Users/RevokeSession/@user.Username">Sessiyanı sonlandır</button>
                                    }
                                </form>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function openDelete(name, action) {
            document.getElementById('deleteTargetName').textContent = name;
            document.getElementById('deleteForm').action = action;
            document.getElementById('deleteOverlay').classList.add('show');
        }

        function closeDelete(e) {
            if (!e || e.target === document.getElementById('deleteOverlay')) {
                document.getElementById('deleteOverlay').classList.remove('show');
            }
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeDelete();
        });
    </script>
}
