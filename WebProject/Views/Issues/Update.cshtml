@model IssueUpdateVM

@{
    ViewData["Title"] = "Edit Issue";
    ViewData["ActivePage"] = "Issues";
}

<div class="topbar">
    <div class="breadcrumb">
        <a asp-action="Index" asp-controller="Home">Dashboard</a>
        <span class="sep">/</span>
        <a asp-action="Index">Issues</a>
        <span class="sep">/</span>
        <span class="current">Edit Issue</span>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-icon blue">✎</div>
        <div>
            <div class="card-title">Edit Issue</div>
            <div class="card-sub">Update the details for this Issue.</div>
        </div>
    </div>

    <form method="post" asp-action="Update" class="form-body" asp-route-id="@Model.Id" id="form">
        @Html.AntiForgeryToken()
        <div class="form-row single">
            <div class="field">
                <label asp-for="Category">Category</label>
                <select asp-for="Category" name="Category" id="categorySelect">
                    <option value="">Select category...</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option selected="@(category == Model.Category ? category : null)" value="@category">@category</option>
                    }
                </select>
                <span asp-validation-for="Category" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field">
                <label asp-for="SubCategory">Sub Category</label>
                <select asp-for = "SubCategory" name="SubCategory" id="subCategorySelect">
                    <option value="">Select category first...</option>
                    @foreach (var category in Model.SubCategories)
                    {
                        <option selected="@(category == Model.SubCategory ? category : null)" value="@category">@category</option>
                    }
                </select>
                <span asp-validation-for="SubCategory" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field" id="f-first">
                <label asp-for="Note">Note</label>
                <textarea id="msg" asp-for="Note" name="Note" rows="4" cols="50" placeholder="Type your note here..."></textarea>
                <span asp-validation-for="Note" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field">
                <label asp-for="Status">Status</label>
                <select asp-for="Status" id="status">
                    <option value="">Select Status...</option>
                    @foreach (var status in Model.Statuses)
                    {
                        <option selected="@(status == Model.Status ? status : null)" value="@status">@status</option>
                    }
                </select>
                <span asp-validation-for="Status" class="err-msg"></span>
            </div>
        </div>
        <button type="submit" class="btn-save">Save Changes</button>
    </form>
</div>