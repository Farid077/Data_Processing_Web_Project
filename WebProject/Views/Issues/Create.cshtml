@model IssueCreateVM

@{
    ViewData["Title"] = "Add Issue";
    ViewData["ActivePage"] = "Issues";
}

<div class="topbar">
    <div class="breadcrumb">
        <a asp-action="Index" asp-controller="Home">Dashboard</a>
        <span class="sep">/</span>
        <a asp-action="Index">Issues</a>
        <span class="sep">/</span>
        <span class="current">Add Issue</span>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-icon">◈</div>
        <div>
            <div class="card-title">Add New Issue</div>
            <div class="card-sub">Fill in the details to create a new Issue.</div>
        </div>
    </div>

    <form method="post" asp asp-action="Create" class="form-body">
        @Html.AntiForgeryToken()

        <div class="form-row single">
            <div class="field">
                <label asp-for="Category">Category</label>
                <select asp-for="Category" name="Category" id="categorySelect">
                    <option value="">Select category...</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option selected="@(category == Model.Category ? category : null)" value="@category">@category</option>
                    }
                </select>
                <span asp-validation-for="Category" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field">
                <label asp-for="SubCategory">Sub Category</label>
                <select asp-for="SubCategory" name="SubCategory" id="subCategorySelect">
                    <option value="">Select sub category...</option>
                    @foreach (var subcategory in Model.SubCategories)
                    {
                        <option selected="@(subcategory == Model.SubCategory ? subcategory : null)" value="@subcategory">@subcategory</option>
                    }
                </select>
                <span asp-validation-for="SubCategory" class="err-msg"></span>
            </div>
        </div>

        <div class="form-row single">
            <div class="field" id="f-first">
                <label asp-for="Note">Note</label>
                <input asp-for="Note" type="text" id="first-name" name="Note">
                @* <textarea id="msg" asp-for="Note" name="Note" rows="4" cols="50" placeholder="Type your note here..."></textarea> *@
                <span asp-validation-for="Note" class="err-msg"></span>
            </div>
        </div>

        <button type="submit" class="btn-save">Create User</button>
    </form>
</div>