            <i class="fas fa-upload me-2"></i>Import Excel
        </button>
        <div id="fileInfo" class="text-white-50 small d-none">
            <i class="fas fa-file-excel text-success me-1"></i>
            <span id="fileNameDisplay"></span>
            <span class="badge bg-success ms-2" id="rowCountBadge"></span>
        </div>
    </div>
</div>

<div>
    @Model
    @* @foreach (var x in Model)
    {
        @x
    }
</div>

<script>
    const App = (() => {
        let state = {
            headers: [],
            page: 1,
            pageSize: 20,
            sortColumn: '',
            sortDir: 'asc',
            search: '',
            columnFilters: {},
            filtersVisible: false,
            editingRowId: null,
            deletingRowId: null
        };

        const $ = id => document.getElementById(id);
        const qs = sel => document.querySelector(sel);

        // ── Toast ────────────────────────────────────────────
        function toast(msg, type = 'success') {
            const el = $('toast');
            el.className = `toast align-items-center border-0 bg-${type} text-white`;
            $('toastMsg').textContent = msg;
            bootstrap.Toast.getOrCreateInstance(el, { delay: 3000 }).show();
        }

        // ── Upload ───────────────────────────────────────────
        function initUpload() {
            const input = $('fileInput');
            input.addEventListener('change', async e => {
                const file = e.target.files[0];
                if (!file) return;
                await uploadFile(file);
                input.value = '';
            });

            const zone = $('uploadZone');
            zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.opacity = '.7'; });
            zone.addEventListener('dragleave', () => { zone.style.opacity = '1'; });
            zone.addEventListener('drop', async e => {
                e.preventDefault();
                zone.style.opacity = '1';
                const file = e.dataTransfer.files[0];
                if (file) await uploadFile(file);
            });
        }

        async function uploadFile(file) {
            const btn = qs('.btn-upload');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Importing...';
            btn.disabled = true;

            const formData = new FormData();
            formData.append('file', file);

            try {
                const res = await fetch('/Home/Upload', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.success) {
                    toast(data.message);
                    $('fileNameDisplay').textContent = file.name;
                    showGridSection();
                    await loadData();
                } else {
                    toast(data.message, 'danger');
                }
            } catch {
                toast('Upload failed. Please try again.', 'danger');
            } finally {
                btn.innerHTML = '<i class="fas fa-upload me-2"></i>Import Excel';
                btn.disabled = false;
            }
        }


        // ── Load data ─────────────────────────────────────────
        async function loadData() {
            const params = new URLSearchParams({
                page: state.page,
                pageSize: state.pageSize,
                searchTerm: state.search,
                sortColumn: state.sortColumn,
                sortDirection: state.sortDir
            });
            Object.entries(state.columnFilters).forEach(([k, v]) => {
                if (v) params.append(`columnFilters[${k}]`, v);
            });

            const res = await fetch('/Home/GetData?' + params);
            const data = await res.json();

            if (!data.headers?.length) return;

            state.headers = data.headers;
            renderHeaders(data.headers);
            renderFilterRow(data.headers);
            renderRows(data.rows, data.headers);
            renderPagination(data);
            updateInfo(data);
            updateRowCountBadge(data.totalCount);
        }

        // ── Render Headers ────────────────────────────────────
        function renderHeaders(headers) {
            const row = $('headerRow');
            row.innerHTML = '';

            headers.forEach(h => {
                const th = document.createElement('th');
                th.className = 'sortable';
                th.dataset.col = h;

                const isSorted = state.sortColumn === h;
                if (isSorted) th.classList.add(`sort-${state.sortDir}`);

                th.innerHTML = `${h}<span class="sort-icon ms-1">${isSorted ? '' : '⇅'}</span>`;
                th.addEventListener('click', () => {
                    if (state.sortColumn === h) {
                        state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc';
                    } else {
                        state.sortColumn = h;
                        state.sortDir = 'asc';
                    }
                    state.page = 1;
                    loadData();
                });
                row.appendChild(th);
            });

            // Actions column
            const th = document.createElement('th');
            th.className = 'action-th';
            th.textContent = 'Actions';
            row.appendChild(th);
        }

        // ── Render Filter Row ─────────────────────────────────
        function renderFilterRow(headers) {
            const row = $('filterRow');
            row.innerHTML = '';

            headers.forEach(h => {
                const th = document.createElement('th');
                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'filter-input';
                input.placeholder = `Filter ${h}...`;
                input.value = state.columnFilters[h] || '';
                input.addEventListener('input', debounce(e => {
                    if (e.target.value) state.columnFilters[h] = e.target.value;
                    else delete state.columnFilters[h];
                    state.page = 1;
                    updateFilterTags();
                    loadData();
                }, 300));
                th.appendChild(input);
                row.appendChild(th);
            });

            const th = document.createElement('th');
            row.appendChild(th);
        }

        // ── Render Rows ───────────────────────────────────────
        function renderRows(rows, headers) {
            const tbody = $('tableBody');
            tbody.innerHTML = '';

            if (!rows.length) {
                tbody.innerHTML = `<tr><td colspan="${headers.length + 1}" class="text-center py-5 text-muted">
                    <i class="fas fa-inbox fa-2x d-block mb-2 opacity-50"></i>No data found</td></tr>`;
                return;
            }

            rows.forEach(row => {
                const tr = document.createElement('tr');
                headers.forEach(h => {
                    const td = document.createElement('td');
                    td.textContent = row.cells[h] ?? '';
                    td.title = row.cells[h] ?? '';
                    tr.appendChild(td);
                });

                // Actions
                const td = document.createElement('td');
                td.className = 'action-td';
                td.innerHTML = `
                    <button class="btn-action btn-edit me-1" data-id="${row.id}" title="Edit">
                        <i class="fas fa-pen"></i>
                    </button>
                    <button class="btn-action btn-delete" data-id="${row.id}" title="Delete">
                        <i class="fas fa-trash"></i>
                    </button>`;
                td.querySelector('.btn-edit').addEventListener('click', () => openEditModal(row));
                td.querySelector('.btn-delete').addEventListener('click', () => openDeleteModal(row.id));
                tr.appendChild(td);

                tbody.appendChild(tr);
            });
        }

        // ── Pagination ────────────────────────────────────────
        function renderPagination(data) {
            const ul = $('pagination');
            ul.innerHTML = '';
            if (data.totalPages <= 1) return;

            const pages = getPaginationRange(data.page, data.totalPages);

            const prev = makePage('‹', data.page - 1, data.page === 1);
            ul.appendChild(prev);

            pages.forEach(p => {
                if (p === '…') {
                    const li = document.createElement('li');
                    li.className = 'page-item disabled';
                    li.innerHTML = '<span class="page-link">…</span>';
                    ul.appendChild(li);
                } else {
                    ul.appendChild(makePage(p, p, false, p === data.page));
                }
            });

            const next = makePage('›', data.page + 1, data.page === data.totalPages);
            ul.appendChild(next);
        }

        function makePage(label, page, disabled, active = false) {
            const li = document.createElement('li');
            li.className = `page-item${disabled ? ' disabled' : ''}${active ? ' active' : ''}`;
            const a = document.createElement('a');
            a.className = 'page-link';
            a.href = '#';
            a.textContent = label;
            if (!disabled && !active) {
                a.addEventListener('click', e => { e.preventDefault(); state.page = page; loadData(); });
            }
            li.appendChild(a);
            return li;
        }

        function getPaginationRange(current, total) {
            if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
            const range = [];
            range.push(1);
            if (current > 3) range.push('…');
            for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) range.push(i);
            if (current < total - 2) range.push('…');
            range.push(total);
            return range;
        }

        // ── Info / badges ─────────────────────────────────────
        function updateInfo(data) {
            const start = (data.page - 1) * data.pageSize + 1;
            const end = Math.min(data.page * data.pageSize, data.totalCount);
            $('resultInfo').textContent = data.totalCount
                ? `Showing ${start}–${end} of ${data.totalCount} rows`
                : 'No rows match your filters';
            $('paginationInfo').textContent = data.totalPages > 1
                ? `Page ${data.page} of ${data.totalPages}` : '';
        }

        function updateRowCountBadge(count) {
            $('rowCountBadge').textContent = `${count} rows`;
            $('fileInfo').classList.remove('d-none');
        }

        function updateFilterTags() {
            const container = $('activeFiltersDisplay');
            container.innerHTML = '';
            const hasFilters = Object.keys(state.columnFilters).some(k => state.columnFilters[k]);
            $('clearFilters').style.display = hasFilters ? '' : 'none';

            Object.entries(state.columnFilters).forEach(([col, val]) => {
                if (!val) return;
                const tag = document.createElement('span');
                tag.className = 'filter-tag';
                tag.innerHTML = `${col}: <strong>${val}</strong> <button onclick="App.clearColumnFilter('${col}')">×</button>`;
                container.appendChild(tag);
            });
        }

        // ── Edit Modal ────────────────────────────────────────
        function openEditModal(row) {
            state.editingRowId = row.id;
            $('editModalTitle').innerHTML = '<i class="fas fa-edit me-2 text-primary"></i>Edit Row';
            const body = $('editModalBody');
            body.innerHTML = '';

            const grid = document.createElement('div');
            grid.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:.75rem;';

            state.headers.forEach(h => {
                const div = document.createElement('div');
                div.className = 'edit-field';
                div.innerHTML = `
                    <div class="edit-label">${h}</div>
                    <input class="edit-input" data-col="${h}" value="${escHtml(row.cells[h] ?? '')}" />`;
                grid.appendChild(div);
            });

            body.appendChild(grid);
            bootstrap.Modal.getOrCreateInstance($('editModal')).show();
        }

        function openAddModal() {
            state.editingRowId = null;
            $('editModalTitle').innerHTML = '<i class="fas fa-plus me-2 text-success"></i>Add New Row';
            const body = $('editModalBody');
            body.innerHTML = '';

            if (!state.headers.length) { toast('No data loaded yet.', 'danger'); return; }

            const grid = document.createElement('div');
            grid.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:.75rem;';

            state.headers.forEach(h => {
                const div = document.createElement('div');
                div.className = 'edit-field';
                div.innerHTML = `
                    <div class="edit-label">${h}</div>
                    <input class="edit-input" data-col="${h}" value="" />`;
                grid.appendChild(div);
            });

            body.appendChild(grid);
            bootstrap.Modal.getOrCreateInstance($('editModal')).show();
        }

        async function saveRow() {
            const inputs = document.querySelectorAll('#editModalBody .edit-input');
            const cells = {};
            inputs.forEach(inp => { cells[inp.dataset.col] = inp.value; });

            const url = state.editingRowId ? '/Home/EditRow' : '/Home/AddRow';
            const body = state.editingRowId
                ? JSON.stringify({ rowId: state.editingRowId, cells })
                : JSON.stringify(cells);

            const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body });
            const data = await res.json();

            if (data.success) {
                bootstrap.Modal.getOrCreateInstance($('editModal')).hide();
                toast(state.editingRowId ? 'Row updated.' : 'Row added.');
                await loadData();
            } else {
                toast(data.message || 'Save failed.', 'danger');
            }
        }

        // ── Delete Modal ──────────────────────────────────────
        function openDeleteModal(id) {
            state.deletingRowId = id;
            bootstrap.Modal.getOrCreateInstance($('deleteModal')).show();
        }

        async function deleteRow() {
            const res = await fetch('/Home/DeleteRow', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(state.deletingRowId)
            });
            const data = await res.json();
            if (data.success) {
                bootstrap.Modal.getOrCreateInstance($('deleteModal')).hide();
                toast('Row deleted.');
                if (state.page > 1) state.page--;
                await loadData();
            }
        }

        // ── Export ────────────────────────────────────────────
        function exportData() {
            const params = new URLSearchParams({
                searchTerm: state.search,
                sortColumn: state.sortColumn,
                sortDirection: state.sortDir
            });
            Object.entries(state.columnFilters).forEach(([k, v]) => {
                if (v) params.append(`columnFilters[${k}]`, v);
            });
            window.location.href = '/Home/Export?' + params;
        }

        // ── UI Helpers ────────────────────────────────────────
        function showGridSection() {
            $('emptyState').classList.add('d-none');
            $('gridSection').classList.remove('d-none');
        }

        function escHtml(str) {
            return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function debounce(fn, delay) {
            let t;
            return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), delay); };
        }

        // ── Public API ────────────────────────────────────────
        function clearColumnFilter(col) {
            delete state.columnFilters[col];
            state.page = 1;
            updateFilterTags();
            // update visible filter inputs
            document.querySelectorAll('#filterRow .filter-input').forEach(inp => {
                const th = inp.closest('th');
                const idx = Array.from(inp.closest('tr').children).indexOf(th);
                if (state.headers[idx] === col) inp.value = '';
            });
            loadData();
        }

        // ── Init ──────────────────────────────────────────────
        function init() {
            initUpload();

            // Search
            $('globalSearch').addEventListener('input', debounce(e => {
                state.search = e.target.value;
                state.page = 1;
                loadData();
            }, 300));

            // Page size
            $('pageSizeSelect').addEventListener('change', e => {
                state.pageSize = +e.target.value;
                state.page = 1;
                loadData();
            });

            // Toggle filters
            $('toggleFilters').addEventListener('click', () => {
                state.filtersVisible = !state.filtersVisible;
                $('filterRow').classList.toggle('d-none', !state.filtersVisible);
                $('toggleFilters').classList.toggle('active', state.filtersVisible);
            });

            // Clear all filters
            $('clearFilters').addEventListener('click', () => {
                state.columnFilters = {};
                state.search = '';
                $('globalSearch').value = '';
                document.querySelectorAll('#filterRow .filter-input').forEach(i => i.value = '');
                state.page = 1;
                updateFilterTags();
                loadData();
            });

            // Add row
            $('addRowBtn').addEventListener('click', openAddModal);

            // Save row
            $('saveRowBtn').addEventListener('click', saveRow);

            // Export
            $('exportBtn').addEventListener('click', exportData);

            // Delete confirm
            $('confirmDeleteBtn').addEventListener('click', deleteRow);

            // Clear data
            $('clearDataBtn').addEventListener('click', async () => {
                if (!confirm('Clear all imported data?')) return;
                await fetch('/Home/ClearData', { method: 'POST' });
                $('emptyState').classList.remove('d-none');
                $('gridSection').classList.add('d-none');
                $('fileInfo').classList.add('d-none');
                toast('Data cleared.');
            });

            // If already has data on page load
            if (!$('emptyState').classList.contains('d-none') === false || document.body.dataset.hasData) {
                // Check if grid is visible from server-side
            }
            if (!$('gridSection').classList.contains('d-none')) {
                loadData();
            }
        }

        return { init, clearColumnFilter };
    })();

    document.addEventListener('DOMContentLoaded', App.init);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script> *@