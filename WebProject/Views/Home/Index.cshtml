@model ExcelData

@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

@* <div class="upload-zone" id="uploadZone">
    <input type="file" id="fileInput" accept=".xlsx,.xls" class="d-none" />
    <div class="d-flex align-items-center gap-3">
