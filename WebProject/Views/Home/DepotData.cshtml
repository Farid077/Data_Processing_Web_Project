@model int

@{
    ViewData["Title"] = $"Depo {Model}";
    ViewData["ActivePage"] = $"Depot {Model}";
}

<div class="depot-page">
    <div class="depot-toolbar">
        @* <button class="btn-accent" onclick="addNewRow()">+ New Row</button> *@
        <div class="depot-search-wrap">
            <span class="search-icon">⌕</span>
            <input type="text" id="global-search" placeholder="Search all columns…" oninput="renderTable()">
        </div>
        <form id="import-form" asp-action="Import" asp-controller="DepotData" asp-route-depot="@Model" method="post" enctype="multipart/form-data" style="display:flex;align-items:center;gap:8px;">
            @Html.AntiForgeryToken()
            <label class="btn-ghost" style="cursor:pointer" title="Import from Excel">
                ⬆ Import Excel Depo @Model
                <input type="file" name="file" accept=".xlsx" style="display:none" onchange="this.form.submit()">
            </label>
        </form>
        <button class="btn-ghost" onclick="clearAllFilters()">Clear Filters</button>
        <span class="row-count" id="row-count"></span>
    </div>

    <div class="depot-alert" id="depot-alert"></div>

    <div class="depot-table-wrap">
        <div class="depot-scroll">
            <table id="depot-table">
                <thead>
                    <tr id="header-row"></tr>
                    <tr class="filter-row" id="filter-row"></tr>
                </thead>
                <tbody id="table-body"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ══════════════════════════════════════════════════════════════════════
//  CONFIG
// ══════════════════════════════════════════════════════════════════════
const API      = '/api/depotdata';
const STATUSES = ['Pending', 'Done', 'Canceled'];

const COLUMNS = [
    // { key: 'id',            label: 'ID',        type: 'number', readOnly: true,  filterable: false, stickyLeft: true  },
    { key: 'sn',            label: 'SN',        type: 'number', filterable: true  },
    { key: 'dqn',           label: 'DQN',       type: 'text',   filterable: true  },
    { key: 'eyNom',         label: 'EyNom',     type: 'text',   filterable: true  },
    { key: 'dvr',           label: 'DVR',       type: 'text',   filterable: true  },
    { key: 'cd',            label: 'CD',        type: 'enum',   filterable: true  },
    { key: 'qapiR',         label: 'QapiR',     type: 'enum',   filterable: true  },
    { key: 'sayKam',        label: 'SayKam',    type: 'enum',   filterable: true  },
    { key: 'hddSt',         label: 'HDDSt',     type: 'enum',   filterable: true  },
    { key: 'hddHc',         label: 'HDDHc',     type: 'enum',   filterable: true  },
    { key: 'hddsm',         label: 'HDDSM',     type: 'enum',   filterable: true  },
    { key: 'dvrSt',         label: 'DVRSt',     type: 'enum',   filterable: true  },
    { key: 'kam',           label: 'Kam',       type: 'combo',  filterable: true  },
    { key: 'kamSt',         label: 'KamSt',     type: 'enum',   filterable: true  },
    { key: 'kamNom',        label: 'KamNom',    type: 'enum',   filterable: true  },
    { key: 'salMon',        label: 'SalMon',    type: 'enum',   filterable: true  },
    { key: 'daySes',        label: 'DaySes',    type: 'enum',   filterable: true  },
    { key: 'surMik',        label: 'SurMik',    type: 'enum',   filterable: true  },
    { key: 'trafared',      label: 'Trafared',  type: 'enum',   filterable: true  },
    { key: 'note',          label: 'Note',      type: 'text',   filterable: false },
    { key: 'confirmedDate', label: 'Date',      type: 'date',   filterable: true  },
    { key: 'isConfirmed',   label: 'Confirmed', type: 'bool',   filterable: true  },
];

// ══════════════════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════════════════
let allData      = [];
let blockedCols  = new Set();
let pinnedColKeys = [];          // user-pinned cols (ordered, left-sticky)
let pinnedRowIds  = new Set();   // user-pinned rows (float to top)
let sortKey      = null;
let sortDir      = 'asc';
let colFilters   = {};           // colKey → Set of selected values
let dateFilters  = [];           // array of 'YYYY-MM-DD'
let _fddPanel     = null;
let _fddActiveCol = null;
let _fddActiveBtn = null;

// ══════════════════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', async () => {
    await loadBlocked();
    buildHeaders();
    buildFilterRow();
    _fddPanel = document.createElement('div');
    _fddPanel.className = 'fdd-panel';
    _fddPanel.id = 'fdd-global-panel';
    _fddPanel.hidden = true;
    document.body.appendChild(_fddPanel);
    await loadData();

    // Close filter dropdowns when clicking outside
    document.addEventListener('click', e => {
        if (!e.target.closest('.fdd-panel')) closeAllDropdowns();
    });
});

async function loadData() {
    const res = await fetch(`${API}?depot=${@Model}`);
    allData = await res.json();
    renderTable();
}

async function loadBlocked() {
    const res = await fetch(`${API}/blocked-columns`);
    blockedCols = new Set(await res.json());
}

// ══════════════════════════════════════════════════════════════════════
//  HEADERS
// ══════════════════════════════════════════════════════════════════════
function buildHeaders() {
    const tr = document.getElementById('header-row');

    COLUMNS.forEach(col => {
        const th = document.createElement('th');
        th.dataset.key = col.key;
        if (col.stickyLeft)           th.classList.add('col-sticky-left');
        if (blockedCols.has(col.key)) th.classList.add('col-blocked');

        th.classList.add('sortable');
        th.addEventListener('click', e => {
            if (e.target.closest('button')) return;
            sortKey = sortKey === col.key && sortDir === 'asc'
                ? (sortDir = 'desc', col.key) : (sortDir = 'asc', col.key);
            updateSortIndicators();
            renderTable();
        });

        const label = document.createElement('span');
        label.className = 'sort-arrow';
        label.textContent = col.label;
        th.appendChild(label);

        if (col.key !== 'id') {
            // Block button
            const blockBtn = document.createElement('button');
            blockBtn.className = 'col-block-btn' + (blockedCols.has(col.key) ? ' active' : '');
            blockBtn.title = 'Block / unblock editing';
            blockBtn.textContent = '🔒';
            blockBtn.onclick = e => { e.stopPropagation(); toggleBlock(col.key); };
            th.appendChild(blockBtn);

            // Pin button
            const pinBtn = document.createElement('button');
            pinBtn.className = 'col-pin-btn' + (pinnedColKeys.includes(col.key) ? ' active' : '');
            pinBtn.title = 'Pin / unpin column (sticky left)';
            pinBtn.textContent = '📌';
            pinBtn.dataset.pinKey = col.key;
            pinBtn.onclick = e => { e.stopPropagation(); togglePinCol(col.key); };
            th.appendChild(pinBtn);
        }

        tr.appendChild(th);
    });

    // Actions column header
    const actTh = document.createElement('th');
    actTh.classList.add('col-sticky-right');
    actTh.dataset.key = '__actions';
    actTh.textContent = 'Actions';
    tr.appendChild(actTh);
}

function updateSortIndicators() {
    document.querySelectorAll('#header-row th').forEach(th => {
        th.classList.remove('sort-asc', 'sort-desc');
        if (th.dataset.key === sortKey)
            th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
    });
}

// ══════════════════════════════════════════════════════════════════════
//  FILTER ROW  — custom dropdowns
// ══════════════════════════════════════════════════════════════════════
function buildFilterRow() {
    const tr = document.getElementById('filter-row');

    COLUMNS.forEach(col => {
        const th = document.createElement('th');
        th.dataset.filterKey = col.key;
        if (col.stickyLeft) th.classList.add('col-sticky-left');

        if (!col.filterable) { tr.appendChild(th); return; }

        if (col.key === 'isConfirmed') {
            // Simple 3-state select
            const sel = document.createElement('select');
            sel.innerHTML = `<option value="">All</option>
                             <option value="true">✔ Yes</option>
                             <option value="false">✗ No</option>`;
            sel.onchange = () => { colFilters[col.key] = sel.value || null; renderTable(); };
            th.appendChild(sel);

        } else if (col.key === 'confirmedDate') {
            const wrap = document.createElement('div');
            const inp  = document.createElement('input');
            inp.type = 'date';
            inp.onchange = () => {
                if (!inp.value || dateFilters.includes(inp.value)) { inp.value = ''; return; }
                dateFilters.push(inp.value); inp.value = '';
                renderDateTags(); renderTable();
            };
            const tags = document.createElement('div');
            tags.id = 'date-tags';
            wrap.appendChild(inp); wrap.appendChild(tags);
            th.appendChild(wrap);

        } else {
            // Custom multi-select dropdown
            const wrap = document.createElement('div');
            wrap.className = 'fdd';
            wrap.dataset.col = col.key;

            const btn = document.createElement('button');
            btn.className = 'fdd-btn';
            btn.innerHTML = `<span class="fdd-label">All</span><span class="fdd-arrow">▾</span>`;
            btn.onclick = e => { e.stopPropagation(); toggleDropdown(wrap); };

            const panel = document.createElement('div');
            panel.className = 'fdd-panel';
            panel.hidden = true;

            wrap.appendChild(btn);
            wrap.appendChild(panel);
            th.appendChild(wrap);
        }

        tr.appendChild(th);
    });

    // Empty cell for Actions
    const actTh = document.createElement('th');
    actTh.classList.add('col-sticky-right');
    tr.appendChild(actTh);
}

function toggleDropdown(wrap) {
    const colKey = wrap.dataset.col;
    const btn    = wrap.querySelector('.fdd-btn');

    // Toggle off if already open for this col
    if (_fddActiveCol === colKey && !_fddPanel.hidden) {
        closeAllDropdowns(); return;
    }

    closeAllDropdowns();
    _fddActiveCol = colKey;
    _fddActiveBtn = btn;

    // Populate checkboxes
    const currentFilter = colFilters[colKey];
    const uniq = [...new Set(allData.map(r => String(r[colKey] ?? '')))].sort();
    _fddPanel.innerHTML = '';
    uniq.forEach(v => {
        const lbl = document.createElement('label');
        const chk = document.createElement('input');
        chk.type    = 'checkbox';
        chk.value   = v;
        chk.checked = currentFilter instanceof Set && currentFilter.has(v);
        chk.onchange = () => updateDropdownFilter(colKey, btn);
        lbl.appendChild(chk);
        lbl.appendChild(document.createTextNode(v === '' ? '(empty)' : v));
        _fddPanel.appendChild(lbl);
    });

    // Position relative to viewport (Fix 2)
    const rect = btn.getBoundingClientRect();
    _fddPanel.style.top      = (rect.bottom + 4) + 'px';
    _fddPanel.style.left     = rect.left + 'px';
    _fddPanel.style.minWidth = Math.max(rect.width, 100) + 'px';
    _fddPanel.hidden = false;
}

function updateDropdownFilter(colKey, btn) {
    const checked = Array.from(_fddPanel.querySelectorAll('input:checked')).map(c => c.value);
    const label   = btn.querySelector('.fdd-label');
    if (checked.length === 0) {
        colFilters[colKey] = null;
        label.textContent  = 'All';
        btn.classList.remove('has-filter');
    } else {
        colFilters[colKey] = new Set(checked);
        label.textContent  = checked.length === 1 ? checked[0] : `${checked.length} selected`;
        btn.classList.add('has-filter');
    }
    renderTable();
}

function closeAllDropdowns() {
    _fddPanel.hidden  = true;
    _fddActiveCol = null;
    _fddActiveBtn = null;
}

function renderDateTags() {
    const c = document.getElementById('date-tags');
    if (!c) return;
    c.innerHTML = '';
    dateFilters.forEach(d => {
        const tag = document.createElement('span');
        tag.className = 'date-tag';
        tag.innerHTML = `${d} <button onclick="removeDateFilter('${d}')">×</button>`;
        c.appendChild(tag);
    });
}
function removeDateFilter(d) {
    dateFilters = dateFilters.filter(x => x !== d);
    renderDateTags(); renderTable();
}

// ══════════════════════════════════════════════════════════════════════
//  RENDER TABLE
// ══════════════════════════════════════════════════════════════════════
function renderTable() {
    const q = document.getElementById('global-search').value.toLowerCase();

    let rows = allData.filter(r => {
        if (q) {
            const txt = COLUMNS.map(c => String(r[c.key] ?? '')).join(' ').toLowerCase();
            if (!txt.includes(q)) return false;
        }
        for (const [k, v] of Object.entries(colFilters)) {
            if (!v) continue;
            if (k === 'isConfirmed') {
                if (v === 'true'  && !r.isConfirmed) return false;
                if (v === 'false' &&  r.isConfirmed) return false;
            } else if (v instanceof Set && v.size > 0) {
                if (!v.has(String(r[k] ?? ''))) return false;
            }
        }
        if (dateFilters.length > 0) {
            const d = r.confirmedDate ? r.confirmedDate.split('T')[0] : '';
            if (!dateFilters.includes(d)) return false;
        }
        return true;
    });

    if (sortKey) {
        rows.sort((a, b) => {
            const c = String(a[sortKey] ?? '').localeCompare(String(b[sortKey] ?? ''), undefined, { numeric: true });
            return sortDir === 'asc' ? c : -c;
        });
    }

    // Pinned rows float to top
    const pinned   = rows.filter(r => pinnedRowIds.has(r.id));
    const unpinned = rows.filter(r => !pinnedRowIds.has(r.id));
    rows = [...pinned, ...unpinned];

    document.getElementById('row-count').textContent = `${rows.length} row${rows.length !== 1 ? 's' : ''}`;
    const tbody = document.getElementById('table-body');
    tbody.innerHTML = '';
    rows.forEach(r => tbody.appendChild(buildDisplayRow(r)));

    applyColPinning();
}

// ══════════════════════════════════════════════════════════════════════
//  DISPLAY ROW
// ══════════════════════════════════════════════════════════════════════
function buildDisplayRow(item) {
    const tr = document.createElement('tr');
    tr.dataset.id = item.id;
    if (item.isConfirmed)       tr.classList.add('confirmed-row');
    if (pinnedRowIds.has(item.id)) tr.classList.add('row-pinned');

    COLUMNS.forEach(col => {
        const td = document.createElement('td');
        if (col.stickyLeft)           td.classList.add('col-sticky-left');
        if (blockedCols.has(col.key)) td.classList.add('col-blocked');

        const v = item[col.key] ?? '';
        if (col.type === 'bool') {
            td.innerHTML = item[col.key]
                ? `<span style="color:var(--accent)">✔</span>`
                : `<span style="color:var(--muted)">✗</span>`;
        } else if (col.type === 'date') {
            td.textContent = v ? String(v).split('T')[0] : '';
        } else {
            td.textContent = v;
        }
        tr.appendChild(td);
    });

    // Actions cell
    const actTd = document.createElement('td');
    actTd.classList.add('col-sticky-right');
    actTd.innerHTML = `<div class="tbl-actions">
        <button class="row-pin-btn ${pinnedRowIds.has(item.id) ? 'active' : ''}"
                title="Pin / unpin row" onclick="togglePinRow(${item.id})">📌</button>
        <button class="tbl-action-btn edit" onclick="startEdit(${item.id})">Redaktə et</button>
        <button class="tbl-action-btn edit" onclick="ConfirmRow(${item.id})">Təsdiq et</button>
    </div>`;
        // <button class="tbl-action-btn del"  onclick="deleteRow(${item.id})">Delete</button>
    tr.appendChild(actTd);
    return tr;
}

// ══════════════════════════════════════════════════════════════════════
//  INLINE EDIT
// ══════════════════════════════════════════════════════════════════════
function startEdit(id) {
    const item = allData.find(x => x.id === id);
    if (!item) return;
    const tr  = document.querySelector(`tr[data-id="${id}"]`);
    const tds = tr.querySelectorAll('td');

    COLUMNS.forEach((col, i) => {
        if (col.readOnly || blockedCols.has(col.key)) return;
        const td = tds[i];
        const v  = item[col.key] ?? '';
        if (col.type === 'bool') ;
            // td.innerHTML = `<input type="checkbox" data-key="${col.key}" ${v ? 'checked' : ''}>`; }
        else if (col.type === 'date') {
            td.innerHTML = `<input type="date" data-key="${col.key}" value="${v ? String(v).split('T')[0] : ''}">`;
        }
        else if (col.type === 'enum') {
            td.innerHTML = buildSelectHtml(col.key, v);
        }
        else if (col.type === 'combo') {
            const custom = v && !STATUSES.includes(v);
            td.innerHTML = `<div class="combo-wrap">
                <select data-key="${col.key}" onchange="comboChange(this)">
                    <option value="">--</option>
                    ${STATUSES.map(s => `<option value="${s}"${v===s?' selected':''}>${s}</option>`).join('')}
                    <option value="__custom__"${custom?' selected':''}>Custom…</option>
                </select>
                <input type="text" data-key="${col.key}-custom" placeholder="Type here…"
                       value="${custom ? esc(v) : ''}" style="${custom ? '' : 'display:none'}">
            </div>`;
        }
        else {
            td.innerHTML = `<input type="${col.type==='number'?'number':'text'}" data-key="${col.key}" value="${esc(String(v))}">`;
        }
    });

    tds[COLUMNS.length].innerHTML = `<div class="tbl-actions">
        <button class="tbl-action-btn save" onclick="saveEdit(${id})">Yadda saxla</button>
        <button class="tbl-action-btn del"  onclick="renderTable()">Ləğv et</button>
    </div>`;
}

function comboChange(sel) {
    const inp = sel.closest('.combo-wrap').querySelector('input[type=text]');
    inp.style.display = sel.value === '__custom__' ? '' : 'none';
    if (sel.value !== '__custom__') inp.value = '';
}

function buildSelectHtml(key, val) {
    return `<select data-key="${key}">
        <option value="">--</option>
        ${STATUSES.map(s => `<option value="${s}"${val===s?' selected':''}>${s}</option>`).join('')}
    </select>`;
}

async function saveEdit(id) {
    const item    = allData.find(x => x.id === id);
    const tr      = document.querySelector(`tr[data-id="${id}"]`);
    const updated = { ...item };

    tr.querySelectorAll('[data-key]').forEach(el => {
        const key = el.dataset.key;
        if (key.endsWith('-custom')) return;
        if (el.type === 'checkbox') {
            updated[key] = el.checked;
        } else if (el.tagName === 'SELECT' && el.value === '__custom__') {
            const c = el.closest('.combo-wrap').querySelector(`[data-key="${key}-custom"]`);
            updated[key] = c?.value.trim() || null;
        } else {
            updated[key] = el.value === '' ? null : el.value;
        }
    });

    try {
        const res = await fetch(`${API}/${id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updated)
        });
        if (!res.ok) throw new Error(await res.text());
        const saved = await res.json();
        allData[allData.findIndex(x => x.id === id)] = saved;
        renderTable();
        showAlert('Saved!', 'success');
    } catch(e) { showAlert('Save failed: ' + e.message, 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  ADD NEW ROW
// ══════════════════════════════════════════════════════════════════════
function addNewRow() {
    if (document.querySelector('tr[data-id="new"]')) return;
    const tbody = document.getElementById('table-body');
    const tr = document.createElement('tr');
    tr.dataset.id = 'new';

    COLUMNS.forEach(col => {
        const td = document.createElement('td');
        if (col.stickyLeft) td.classList.add('col-sticky-left');

        if (col.key === 'id') {
            td.innerHTML = `<span style="color:var(--text-dim);font-size:11px">new</span>`;
        } else if (col.type === 'bool') {
            td.innerHTML = `<input type="checkbox" data-key="${col.key}">`;
        } else if (col.type === 'date') {
            td.innerHTML = `<input type="date" data-key="${col.key}">`;
        } else if (col.type === 'enum') {
            td.innerHTML = buildSelectHtml(col.key, '');
        } else if (col.type === 'combo') {
            td.innerHTML = `<div class="combo-wrap">
                <select data-key="${col.key}" onchange="comboChange(this)">
                    <option value="">--</option>
                    ${STATUSES.map(s => `<option value="${s}">${s}</option>`).join('')}
                    <option value="__custom__">Custom…</option>
                </select>
                <input type="text" data-key="${col.key}-custom" placeholder="Type here…" style="display:none">
            </div>`;
        } else {
            td.innerHTML = `<input type="text" data-key="${col.key}" placeholder="${col.label}">`;
        }
        tr.appendChild(td);
    });

    const actTd = document.createElement('td');
    actTd.classList.add('col-sticky-right');
    actTd.innerHTML = `<div class="tbl-actions">
        <button class="tbl-action-btn save"   onclick="createRow()">Create</button>
        <button class="tbl-action-btn del" onclick="this.closest('tr').remove()">Cancel</button>
    </div>`;
    tr.appendChild(actTd);
    tbody.prepend(tr);
    tr.querySelector('input[data-key="dqn"]')?.focus();
}

async function createRow() {
    const tr   = document.querySelector('tr[data-id="new"]');
    const body = {};
    tr.querySelectorAll('[data-key]').forEach(el => {
        const key = el.dataset.key;
        if (key.endsWith('-custom')) return;
        if (el.type === 'checkbox') {
            body[key] = el.checked;
        } else if (el.tagName === 'SELECT' && el.value === '__custom__') {
            const c = el.closest('.combo-wrap').querySelector(`[data-key="${key}-custom"]`);
            body[key] = c?.value.trim() || null;
        } else {
            body[key] = el.value === '' ? null : el.value;
        }
    });
    if (!body.dqn) { showAlert('DQN is required.', 'danger'); return; }
    try {
        const res = await fetch(API, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (!res.ok) throw new Error(await res.text());
        allData.unshift(await res.json());
        renderTable();
        showAlert('Row created!', 'success');
    } catch(e) { showAlert('Create failed: ' + e.message, 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  DELETE
// ══════════════════════════════════════════════════════════════════════
async function deleteRow(id) {
    if (!confirm('Delete this row?')) return;
    try {
        const res = await fetch(`${API}/${id}`, { method: 'DELETE' });
        if (!res.ok) throw new Error();
        allData = allData.filter(x => x.id !== id);
        renderTable();
        showAlert('Deleted.', 'warning');
    } catch { showAlert('Delete failed.', 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  CONFIRM
// ══════════════════════════════════════════════════════════════════════
async function ConfirmRow(id) {
    if (!confirm('Confirm this row?')) return;
    try {
        const res = await fetch(`${API}/Confirm/${id}`, { method: 'POST' });
        if (!res.ok) throw new Error();
        // allData = allData.filter(x => x.id !== id);
        const saved = await res.json();
        allData[allData.findIndex(x => x.id === id)] = saved;
        renderTable();
        showAlert('Confirmed.', 'success');
    } catch { showAlert('Confirm failed.', 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  BLOCK COLUMN
// ══════════════════════════════════════════════════════════════════════
async function toggleBlock(colKey) {
    try {
        const res = await fetch(`${API}/blocked-columns/${colKey}`, { method: 'POST' });
        if (!res.ok) throw new Error();
        blockedCols = new Set(await res.json());
        document.querySelectorAll('#header-row th').forEach(th => {
            const k = th.dataset.key;
            if (!k || k === '__actions') return;
            th.classList.toggle('col-blocked', blockedCols.has(k));
            th.querySelector('.col-block-btn')?.classList.toggle('active', blockedCols.has(k));
        });
        renderTable();
        showAlert(`"${colKey}" ${blockedCols.has(colKey) ? 'blocked 🔒' : 'unblocked 🔓'}`, 'info');
    } catch { showAlert('Block toggle failed.', 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  PIN COLUMN
// ══════════════════════════════════════════════════════════════════════
function togglePinCol(colKey) {
    if (pinnedColKeys.includes(colKey)) {
        pinnedColKeys = pinnedColKeys.filter(k => k !== colKey);
    } else {
        pinnedColKeys.push(colKey);
    }
    // Update pin button styles
    document.querySelectorAll('.col-pin-btn').forEach(btn => {
        btn.classList.toggle('active', pinnedColKeys.includes(btn.dataset.pinKey));
    });
    renderTable();
}

function applyColPinning() {
    // Clear old pins
    document.querySelectorAll('#depot-table .col-pinned').forEach(el => {
        el.classList.remove('col-pinned');
        el.style.removeProperty('position');
        el.style.removeProperty('left');
        el.style.removeProperty('z-index');
        el.style.removeProperty('background');
    });

    if (pinnedColKeys.length === 0) return;

    // Wait for layout to fully settle before reading widths (Fix 4)
    requestAnimationFrame(() => requestAnimationFrame(() => {
        const idTh = document.querySelector('#header-row th[data-key="id"]');
        let offset = idTh ? idTh.getBoundingClientRect().width : 60;

        pinnedColKeys.forEach(colKey => {
            const colIdx  = COLUMNS.findIndex(c => c.key === colKey);
            if (colIdx === -1) return;

            const headerTh = document.querySelector(`#header-row th:nth-child(${colIdx + 1})`);
            const colWidth = headerTh ? headerTh.getBoundingClientRect().width : 100;

            document.querySelectorAll('#depot-table tr').forEach(tr => {
                const cell = tr.children[colIdx];
                if (!cell) return;
                const inHead = !!tr.closest('thead');
                cell.classList.add('col-pinned');
                cell.style.position   = 'sticky';
                cell.style.left       = offset + 'px';
                cell.style.zIndex     = inHead ? '18' : '3';
                cell.style.background = 'var(--surface)'; // always correct regardless of theme
            });

            offset += colWidth;
        });
    }));
}

// ══════════════════════════════════════════════════════════════════════
//  PIN ROW
// ══════════════════════════════════════════════════════════════════════
function togglePinRow(id) {
    if (pinnedRowIds.has(id)) pinnedRowIds.delete(id);
    else pinnedRowIds.add(id);
    renderTable();
}

// ══════════════════════════════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════════════════════════════
function clearAllFilters() {
    colFilters  = {};
    dateFilters = [];
    document.getElementById('global-search').value = '';
    // Reset dropdown labels
    document.querySelectorAll('.fdd-btn').forEach(btn => {
        btn.querySelector('.fdd-label').textContent = 'All';
        btn.classList.remove('has-filter');
    });
    document.querySelectorAll('.filter-row select').forEach(s => s.value = '');
    renderDateTags();
    renderTable();
}

function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function showAlert(msg, type) {
    const el = document.getElementById('depot-alert');
    el.className = `depot-alert show ${type}`;
    el.textContent = msg;
    clearTimeout(el._t);
    el._t = setTimeout(() => el.classList.remove('show'), 3000);
}
</script>
}
