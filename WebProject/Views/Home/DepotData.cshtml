@model int

@{
    ViewData["Title"] = $"Depo {Model}";
    ViewData["ActivePage"] = $"Depot {Model}";
}

@Html.AntiForgeryToken()

@{
    bool IsAdmin = User.IsInRole("SuperAdmin") || User.IsInRole("Admin");
}

<div class="depot-page">
    <div class="depot-toolbar">
        <button class="btn-accent" onclick="addNewRow()">+ New Row</button>
        <div class="depot-search-wrap">
            <span class="search-icon">⌕</span>
            <input type="text" id="global-search" placeholder="Search all columns…" oninput="renderTable()">
        </div>
        @* <form id="import-form" asp-action="Import" asp-controller="DepotData"
              asp-route-depot="@Model" method="post" enctype="multipart/form-data"
              style="display:flex;align-items:center;gap:8px;">
            @Html.AntiForgeryToken()
            <label class="btn-ghost" style="cursor:pointer" title="Import from Excel">
                ⬆ Import Excel
                <input type="file" name="file" accept=".xlsx" style="display:none" onchange="this.form.submit()">
            </label>
        </form> *@

        <label class="btn-ghost" style="cursor:pointer" title="Import from Excel">
            ⬆ Import Excel
            <input type="file" accept=".xlsx" style="display:none"
                   onchange="importExcel(this)">
        </label>

        <button class="btn-ghost" onclick="exportFiltered()">⬇ Export Excel</button>
        <button class="btn-ghost" onclick="openOptionsManager()">⚙ Options</button>
        <button class="btn-ghost" onclick="clearAllFilters()">Clear Filters</button>
        <span class="row-count" id="row-count"></span>
    </div>

    <div class="depot-alert" id="depot-alert"></div>

    <div class="depot-table-wrap">
        <div class="depot-scroll">
            <table id="depot-table">
                <thead>
                    <tr id="header-row"></tr>
                    <tr class="filter-row" id="filter-row"></tr>
                </thead>
                <tbody id="table-body"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>

const isAdmin = "@IsAdmin";

const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

// ══════════════════════════════════════════════════════════════════════
//  CONFIG
// ══════════════════════════════════════════════════════════════════════
const API = '/api/depotdata';

// COLUMNS — type: 'text'|'number'|'enum'|'combo'|'bool'|'date'
// optionsKey  : key in OPTIONS dict  (for enum / combo)
// dateFilter  : true → multi-date picker filter
// readOnly    : not editable
const COLUMNS = [
    { key: 'sn',            label: 'SN',                  type: 'number', filterable: true                                      },
    { key: 'dqn',           label: 'DQN',                 type: 'text',   readOnly: true,    filterable: true                   },
    { key: 'eyNom',         label: 'Ey. N.',              type: 'text',   readOnly: true,    filterable: true                   },
    { key: 'dvr',           label: 'DVR Versiya',         type: 'text',   readOnly: true,    filterable: true                   },
    { key: 'cd',            label: 'Connect',             type: 'enum',   filterable: true,  optionsKey: 'CDOptions'            },
    { key: 'qapiR',         label: 'Qapi və R',           type: 'enum',   filterable: true,  optionsKey: 'QapiROptions'         },
    { key: 'sayKam',        label: 'Sayım Kameraları',    type: 'enum',   filterable: true,  optionsKey: 'SayKamOptions'        },
    { key: 'hddv',          label: 'HDD Vəziyyəti',       type: 'enum',   filterable: true,  optionsKey: 'HDDVOptions'          },
    { key: 'hddh',          label: 'HDD Həcmi',           type: 'enum',   filterable: true,  optionsKey: 'HDDHOptions'          },
    { key: 'hddsm',         label: 'HDD Saxlama Müddəti', type: 'enum',   filterable: true,  optionsKey: 'HDDSMOptions'         },
    { key: 'dvrv',          label: 'DVR Vəziyyəti',       type: 'enum',   filterable: true,  optionsKey: 'DVRVOptions'          },
    { key: 'kam',           label: 'Kamera',              type: 'combo',  filterable: true,  optionsKey: 'KamOptions'           },
    { key: 'kamV',          label: 'Kamera Vəziyyəti',    type: 'enum',   filterable: true,  optionsKey: 'KamVOptions'          },
    { key: 'kamNom',        label: 'Kamera Nömrəsi',      type: 'enum',   filterable: true,  optionsKey: 'KamNomOptions'        },
    { key: 'salMon',        label: 'Salon Monitoru',      type: 'enum',   filterable: true,  optionsKey: 'SalMonOptions'        },
    { key: 'daySes',        label: 'Dayanacaq Səs.',      type: 'enum',   filterable: true,  optionsKey: 'DaySesOptions'        },
    { key: 'surMik',        label: 'Sürücü Mik.',         type: 'enum',   filterable: true,  optionsKey: 'SurMikOptions'        },
    { key: 'trafared',      label: 'Trafared',            type: 'enum',   filterable: true,  optionsKey: 'TrafaredOptions'      },
    { key: 'qeyd',          label: 'Qeyd',                type: 'text',   filterable: true                                      },
    { key: 'isConfirmed',   label: 'Təsdiqlənmə',         type: 'bool',   filterable: true                                      },
    { key: 'confirmedDate', label: 'Təsdiqlənib',         type: 'date',   readOnly: true,    filterable: true, dateFilter: true },
    { key: 'updatedTime',   label: 'Redaktə olunub',      type: 'date',   readOnly: true,    filterable: true, dateFilter: true },
    { key: 'confirmerId',   label: 'Təsdiqləyən',         type: 'text',   readOnly: true,    filterable: true                   },
];

// ══════════════════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════════════════
let allData       = [];
let OPTIONS       = {};           // { 'CDOptions': ['v1','v2'], ... }
let blockedCols   = new Set();
let blockedRowIds = new Set();
let pinnedColKeys = [];
let pinnedRowIds  = new Set();
let sortKey       = "sn";
let sortDir       = 'asc';
let colFilters    = {};           // colKey → Set | string
let dateFiltersMap = {};          // colKey → string[]  (generic, supports all date cols)
let _fddPanel     = null;
let _fddActiveCol = null;
let _fddActiveBtn = null;

// ══════════════════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', async () => {
    // Global filter dropdown panel
    _fddPanel = document.createElement('div');
    _fddPanel.className = 'fdd-panel';
    _fddPanel.id = 'fdd-global-panel';
    _fddPanel.hidden = true;
    document.body.appendChild(_fddPanel);

    await Promise.all([loadBlocked(), loadBlockedRows(), loadOptions()]);
    buildHeaders();
    buildFilterRow();
    await loadData();

    document.addEventListener('click', e => {
        if (!e.target.closest('.fdd-panel') && !e.target.closest('.fdd')) closeAllDropdowns();
    });
});

async function loadData() {
    const res = await fetch(`${API}?depot=@Model`);
    allData = await res.json();
    renderTable();
}

async function loadBlocked() {
    const res = await fetch(`${API}/blocked-columns`);
    blockedCols = new Set(await res.json());
}

async function loadBlockedRows() {
    const res = await fetch(`${API}/blocked-rows`);
    blockedRowIds = new Set((await res.json()).map(String));
}

async function loadOptions() {
    const res = await fetch(`${API}/options`);
    OPTIONS = await res.json();
}

function getOpts(col) {
    return col.optionsKey ? (OPTIONS[col.optionsKey] || []) : [];
}

// ══════════════════════════════════════════════════════════════════════
//  HEADERS
// ══════════════════════════════════════════════════════════════════════
function buildHeaders() {
    const tr = document.getElementById('header-row');
    COLUMNS.forEach(col => {
        const th = document.createElement('th');
        th.dataset.key = col.key;
        if (col.stickyLeft)           th.classList.add('col-sticky-left');
        if (blockedCols.has(col.key)) th.classList.add('col-blocked');

        th.classList.add('sortable');
        th.addEventListener('click', e => {
            if (e.target.closest('button')) return;
            if (sortKey === col.key) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
            else { sortKey = col.key; sortDir = 'asc'; }
            updateSortIndicators(); renderTable();
        });

        const label = document.createElement('span');
        label.className = 'sort-arrow';
        label.textContent = col.label;
        th.appendChild(label);

        // Block col button
        const blockBtn = document.createElement('button');
        blockBtn.className = 'col-block-btn' + (blockedCols.has(col.key) ? ' active' : '');
        blockBtn.title = 'Sütunu kilidlə / aç';
        blockBtn.textContent = '🔒';
        blockBtn.onclick = e => { e.stopPropagation(); toggleBlock(col.key); };
        th.appendChild(blockBtn);

        // Pin col button
        const pinBtn = document.createElement('button');
        pinBtn.className = 'col-pin-btn' + (pinnedColKeys.includes(col.key) ? ' active' : '');
        pinBtn.title = 'Sütunu sabit et / aç';
        pinBtn.textContent = '📌';
        pinBtn.dataset.pinKey = col.key;
        pinBtn.onclick = e => { e.stopPropagation(); togglePinCol(col.key); };
        th.appendChild(pinBtn);

        tr.appendChild(th);
    });

    const actTh = document.createElement('th');
    actTh.classList.add('col-sticky-right');
    actTh.dataset.key = '__actions';
    actTh.textContent = 'Əməliyyatlar';
    tr.appendChild(actTh);
}

function updateSortIndicators() {
    document.querySelectorAll('#header-row th').forEach(th => {
        th.classList.remove('sort-asc', 'sort-desc');
        if (th.dataset.key === sortKey)
            th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
    });
}

// ══════════════════════════════════════════════════════════════════════
//  FILTER ROW
// ══════════════════════════════════════════════════════════════════════
function buildFilterRow() {
    const tr = document.getElementById('filter-row');
    COLUMNS.forEach(col => {
        const th = document.createElement('th');
        th.dataset.filterKey = col.key;
        if (col.stickyLeft) th.classList.add('col-sticky-left');

        if (!col.filterable) { tr.appendChild(th); return; }

        if (col.key === 'isConfirmed') {
            const sel = document.createElement('select');
            sel.innerHTML = `<option value="">Hamısı</option>
                             <option value="true">✔ Bəli</option>
                             <option value="false">✗ Xeyr</option>`;
            sel.onchange = () => { colFilters[col.key] = sel.value || null; renderTable(); };
            th.appendChild(sel);

        } else if (col.dateFilter) {
            // Generic multi-date picker for any date column
            const wrap = document.createElement('div');
            const inp  = document.createElement('input');
            inp.type = 'date';
            inp.onchange = () => {
                if (!inp.value) return;
                if (!dateFiltersMap[col.key]) dateFiltersMap[col.key] = [];
                if (!dateFiltersMap[col.key].includes(inp.value)) {
                    dateFiltersMap[col.key].push(inp.value);
                    renderDateTags(col.key);
                    renderTable();
                }
                inp.value = '';
            };
            const tags = document.createElement('div');
            tags.id = `date-tags-${col.key}`;
            wrap.appendChild(inp); wrap.appendChild(tags);
            th.appendChild(wrap);

        } else {
            const wrap = document.createElement('div');
            wrap.className = 'fdd';
            wrap.dataset.col = col.key;
            const btn = document.createElement('button');
            btn.className = 'fdd-btn';
            btn.innerHTML = `<span class="fdd-label">Hamısı</span><span class="fdd-arrow">▾</span>`;
            btn.onclick = e => { e.stopPropagation(); toggleDropdown(wrap); };
            wrap.appendChild(btn);
            th.appendChild(wrap);
        }

        tr.appendChild(th);
    });

    const actTh = document.createElement('th');
    actTh.classList.add('col-sticky-right');
    tr.appendChild(actTh);
}

// ── Date tag helpers ─────────────────────────────────────────────────
function renderDateTags(colKey) {
    const c = document.getElementById(`date-tags-${colKey}`);
    if (!c) return;
    c.innerHTML = '';
    (dateFiltersMap[colKey] || []).forEach(d => {
        const tag = document.createElement('span');
        tag.className = 'date-tag';
        tag.innerHTML = `${d} <button onclick="removeDateFilter('${colKey}','${d}')">×</button>`;
        c.appendChild(tag);
    });
}
function removeDateFilter(colKey, d) {
    dateFiltersMap[colKey] = (dateFiltersMap[colKey] || []).filter(x => x !== d);
    renderDateTags(colKey); renderTable();
}

// ── Custom multi-select dropdown ─────────────────────────────────────
function toggleDropdown(wrap) {
    const colKey = wrap.dataset.col;
    const btn    = wrap.querySelector('.fdd-btn');
    if (_fddActiveCol === colKey && !_fddPanel.hidden) { closeAllDropdowns(); return; }
    closeAllDropdowns();
    _fddActiveCol = colKey;
    _fddActiveBtn = btn;

    const currentFilter = colFilters[colKey];
    const uniq = [...new Set(allData.map(r => String(r[colKey] ?? '')))].sort();
    _fddPanel.innerHTML = '';
    uniq.forEach(v => {
        const lbl = document.createElement('label');
        const chk = document.createElement('input');
        chk.type    = 'checkbox';
        chk.value   = v;
        chk.checked = currentFilter instanceof Set && currentFilter.has(v);
        chk.onchange = () => { updateDropdownFilter(colKey, btn); renderTable(); }
        lbl.appendChild(chk);
        lbl.appendChild(document.createTextNode(v === '' ? '(boş)' : v));
        _fddPanel.appendChild(lbl);
    });

    const rect = btn.getBoundingClientRect();
    _fddPanel.style.top      = (rect.bottom + 4) + 'px';
    _fddPanel.style.left     = rect.left + 'px';
    _fddPanel.style.minWidth = Math.max(rect.width, 120) + 'px';
    _fddPanel.hidden = false;
}

function updateDropdownFilter(colKey, btn) {
    const checked = Array.from(_fddPanel.querySelectorAll('input:checked')).map(c => c.value);
    const label   = btn.querySelector('.fdd-label');
    if (checked.length === 0) {
        colFilters[colKey] = null;
        label.textContent  = 'Hamısı';
        btn.classList.remove('has-filter');
    } else {
        colFilters[colKey] = new Set(checked);
        label.textContent  = checked.length === 1 ? checked[0] : `${checked.length} seçildi`;
        btn.classList.add('has-filter');
    }
    // Don't close — user may want to select more
}

function closeAllDropdowns() {
    if (!_fddPanel.hidden);
    _fddPanel.hidden = true;
    _fddActiveCol = null;
    _fddActiveBtn = null;
}

// ══════════════════════════════════════════════════════════════════════
//  RENDER TABLE
// ══════════════════════════════════════════════════════════════════════
function renderTable() {
    const q = document.getElementById('global-search').value.toLowerCase();

    let rows = allData.filter(r => {
        // Global search
        if (q) {
            const txt = COLUMNS.map(c => String(r[c.key] ?? '')).join(' ').toLowerCase();
            if (!txt.includes(q)) return false;
        }
        // Column filters
        for (const [k, v] of Object.entries(colFilters)) {
            if (!v) continue;
            if (k === 'isConfirmed') {
                if (v === 'true'  && !r.isConfirmed) return false;
                if (v === 'false' &&  r.isConfirmed) return false;
            } else if (v instanceof Set && v.size > 0) {
                if (!v.has(String(r[k] ?? ''))) return false;
            }
        }
        // Date filters (generic — works for any column with dateFilter:true)
        for (const col of COLUMNS.filter(c => c.dateFilter)) {
            const filters = dateFiltersMap[col.key];
            if (!filters || filters.length === 0) continue;
            const rowDate = r[col.key] ? String(r[col.key]).split('T')[0] : '';
            if (!filters.includes(rowDate)) return false;
        }
        return true;
    });

    if (sortKey) {
        rows.sort((a, b) => {
            const c = String(a[sortKey] ?? '').localeCompare(String(b[sortKey] ?? ''), undefined, { numeric: true });
            return sortDir === 'asc' ? c : -c;
        });
    }

    // Pinned rows float to top
    rows = [...rows.filter(r => pinnedRowIds.has(r.id)), ...rows.filter(r => !pinnedRowIds.has(r.id))];

    document.getElementById('row-count').textContent = `${rows.length} sıra`;
    const tbody = document.getElementById('table-body');
    tbody.innerHTML = '';
    rows.forEach(r => tbody.appendChild(buildDisplayRow(r)));
    applyColPinning();
}

// ══════════════════════════════════════════════════════════════════════
//  DISPLAY ROW
// ══════════════════════════════════════════════════════════════════════
function buildDisplayRow(item) {
    const tr = document.createElement('tr');
    tr.dataset.id = item.id;
    if (item.isConfirmed)           tr.classList.add('confirmed-row');
    if (pinnedRowIds.has(item.id))  tr.classList.add('row-pinned');
    if (blockedRowIds.has(String(item.id))) tr.classList.add('row-blocked');

    COLUMNS.forEach(col => {
        const td = document.createElement('td');
        if (col.stickyLeft)           td.classList.add('col-sticky-left');
        if (blockedCols.has(col.key)) td.classList.add('col-blocked');
        if (col.key === 'qeyd')       td.classList.add('col-qeyd');

        const v = item[col.key] ?? '';
        if (col.type === 'bool') {
            td.innerHTML = item[col.key]
                ? `<span style="color:var(--accent)">✔</span>`
                : `<span style="color:var(--muted)">✗</span>`;
        } else if (col.type === 'date') {
            td.textContent = v ? new Date(v).toISOString().replace('T',' ').substring(0,19) : '';
        } else {
            td.textContent = v;
        }
        tr.appendChild(td);
    });

    const isBlocked = blockedRowIds.has(String(item.id));
    const isPinned  = pinnedRowIds.has(item.id);

    const actTd = document.createElement('td');
    actTd.classList.add('col-sticky-right');
    actTd.innerHTML = `<div class="tbl-actions">
        <button class="row-pin-btn ${isPinned ? 'active' : ''}"
                title="Sıranı sabit et / aç" onclick="togglePinRow(${item.id})">📌</button>
        <button class="row-block-btn ${isBlocked ? 'active' : ''}"
                title="Sıranı kilidlə / aç" onclick="toggleBlockRow(${item.id})">🔒</button>
        <button class="tbl-action-btn edit" onclick="startEdit(${item.id})">Redaktə et</button>
        <button class="tbl-action-btn edit" onclick="ConfirmRow(${item.id})">Təsdiq et</button>
    </div>`;
    tr.appendChild(actTd);
    return tr;
}

// ══════════════════════════════════════════════════════════════════════
//  INLINE EDIT
// ══════════════════════════════════════════════════════════════════════
function startEdit(id) {
    const item = allData.find(x => x.id === id);
    if (!item) return;
    const tr  = document.querySelector(`tr[data-id="${id}"]`);
    const tds = tr.querySelectorAll('td');

    COLUMNS.forEach((col, i) => {
        if ((col.readOnly || blockedCols.has(col.key)) && (!isAdmin)) return;
        const td = tds[i];
        const v  = item[col.key] ?? '';

        if (col.type === 'bool') {
            td.innerHTML = `<input type="checkbox" data-key="${col.key}" ${v ? 'checked' : ''}>`;
        } else if (col.type === 'date') {
            td.innerHTML = `<input type="date" data-key="${col.key}" value="${v ? String(v).split('T')[0] : ''}">`;
        } else if (col.type === 'enum') {
            td.innerHTML = buildSelectHtml(col.key, v, getOpts(col));
        } else if (col.type === 'combo') {
            td.innerHTML = buildComboHtml(col.key, v, getOpts(col));
        } else {
            td.innerHTML = `<input type="${col.type==='number'?'number':'text'}" data-key="${col.key}" value="${esc(String(v))}">`;
        }
    });

    tds[COLUMNS.length].innerHTML = `<div class="tbl-actions">
        <button class="tbl-action-btn save" onclick="saveEdit(${id})">Yadda saxla</button>
        <button class="tbl-action-btn del"  onclick="renderTable()">Ləğv et</button>
    </div>`;

    // Enter to save (skip note field)
    tr.querySelectorAll('input, select').forEach(el => {
        if (el.dataset.key === 'qeyd') return;
        el.addEventListener('keydown', e => { if (e.key === 'Enter') saveEdit(id); });
    });
}

function comboChange(sel) {
    const inp = sel.closest('.combo-wrap').querySelector('input[type=text]');
    inp.style.display = sel.value === '__custom__' ? '' : 'none';
    if (sel.value !== '__custom__') inp.value = '';
}

function buildSelectHtml(key, val, opts) {
    return `<select data-key="${key}">
        <option value="">--</option>
        ${opts.map(s => `<option value="${s}"${val===s?' selected':''}>${s}</option>`).join('')}
    </select>`;
}

function buildComboHtml(key, val, opts) {
    const custom = val && !opts.includes(val);
    return `<div class="combo-wrap">
        <select data-key="${key}" onchange="comboChange(this)">
            <option value="">--</option>
            ${opts.map(s => `<option value="${s}"${val===s?' selected':''}>${s}</option>`).join('')}
            <option value="__custom__"${custom?' selected':''}>Əl ilə yaz…</option>
        </select>
        <input type="text" data-key="${key}-custom" placeholder="Dəyər daxil edin…"
               value="${custom ? esc(val) : ''}" style="${custom ? '' : 'display:none'}">
    </div>`;
}

async function saveEdit(id) {
    const item    = allData.find(x => x.id === id);
    const tr      = document.querySelector(`tr[data-id="${id}"]`);
    const updated = { ...item };

    tr.querySelectorAll('[data-key]').forEach(el => {
        const key = el.dataset.key;
        if (key.endsWith('-custom')) return;
        if (el.type === 'checkbox') {
            updated[key] = el.checked;
        } else if (el.tagName === 'SELECT' && el.value === '__custom__') {
            const c = el.closest('.combo-wrap').querySelector(`[data-key="${key}-custom"]`);
            updated[key] = c?.value.trim() || null;
        } else {
            updated[key] = el.value === '' ? null : el.value;
        }
    });

    try {
        const res = await fetch(`${API}/${id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify(updated)
        });
        if (!res.ok) throw new Error(await res.text());
        const saved = await res.json();
        allData[allData.findIndex(x => x.id === id)] = saved;
        renderTable();
        showAlert('Yadda saxlandı!', 'success');
    } catch(e) { showAlert('Xəta: ' + e.message, 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  ADD NEW ROW
// ══════════════════════════════════════════════════════════════════════
function addNewRow() {
    if (document.querySelector('tr[data-id="new"]')) return;
    const tbody = document.getElementById('table-body');
    const tr = document.createElement('tr');
    tr.dataset.id = 'new';

    COLUMNS.forEach(col => {
        const td = document.createElement('td');
        if (col.stickyLeft) td.classList.add('col-sticky-left');

        if (col.readOnly) {
            td.innerHTML = `<span style="color:var(--muted);font-size:11px">auto</span>`;
        } else if (col.type === 'bool') {
            td.innerHTML = `<input type="checkbox" data-key="${col.key}">`;
        } else if (col.type === 'date') {
            td.innerHTML = `<input type="date" data-key="${col.key}">`;
        } else if (col.type === 'enum') {
            td.innerHTML = buildSelectHtml(col.key, '', getOpts(col));
        } else if (col.type === 'combo') {
            td.innerHTML = buildComboHtml(col.key, '', getOpts(col));
        } else {
            td.innerHTML = `<input type="text" data-key="${col.key}" placeholder="${col.label}">`;
        }
        tr.appendChild(td);
    });

    const actTd = document.createElement('td');
    actTd.classList.add('col-sticky-right');
    actTd.innerHTML = `<div class="tbl-actions">
        <button class="tbl-action-btn save" onclick="createRow()">Əlavə et</button>
        <button class="tbl-action-btn del"  onclick="this.closest('tr').remove()">Ləğv et</button>
    </div>`;
    tr.appendChild(actTd);
    tbody.prepend(tr);
    tr.querySelector('input[data-key="dqn"]')?.focus();
}

async function createRow() {
    const tr   = document.querySelector('tr[data-id="new"]');
    const body = { depot: @Model };
    tr.querySelectorAll('[data-key]').forEach(el => {
        const key = el.dataset.key;
        if (key.endsWith('-custom')) return;
        if (el.type === 'checkbox') {
            body[key] = el.checked;
        } else if (el.tagName === 'SELECT' && el.value === '__custom__') {
            const c = el.closest('.combo-wrap').querySelector(`[data-key="${key}-custom"]`);
            body[key] = c?.value.trim() || null;
        } else {
            body[key] = el.value === '' ? null : el.value;
        }
    });
    if (!body.dqn) { showAlert('DQN tələb olunur.', 'danger'); return; }
    try {
        const res = await fetch(API, {
            method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify(body)
        });
        if (!res.ok) throw new Error(await res.text());
        allData.unshift(await res.json());
        renderTable();
        showAlert('Əlavə edildi!', 'success');
    } catch(e) { showAlert('Xəta: ' + e.message, 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  CONFIRM
// ══════════════════════════════════════════════════════════════════════
async function ConfirmRow(id) {
    if (!confirm('Bu sıranı təsdiqləyirsiniz?')) return;
    try {
        const res = await fetch(`${API}/Confirm/${id}`, { method: 'POST',
            headers: {
                'RequestVerificationToken': TOKEN
            }
        });
        if (!res.ok) throw new Error();
        const saved = await res.json();
        allData[allData.findIndex(x => x.id === id)] = saved;
        renderTable();
        showAlert('Təsdiqləndi.', 'success');
    } catch { showAlert('Təsdiqləmə xətası.', 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  DELETE
// ══════════════════════════════════════════════════════════════════════
async function deleteRow(id) {
    if (!confirm('Bu sıranı silirsiniz?')) return;
    try {
        const res = await fetch(`${API}/${id}`, {
            method: 'DELETE',
            headers: {
                'RequestVerificationToken': TOKEN
            }
        });
        if (!res.ok) throw new Error();
        allData = allData.filter(x => x.id !== id);
        renderTable();
        showAlert('Silindi.', 'warning');
    } catch { showAlert('Silmə xətası.', 'danger'); }
}

// ══════════════════════════════════════════════════════════════════════
//  BLOCK COLUMN
// ══════════════════════════════════════════════════════════════════════
async function toggleBlock(colKey) {
    try {
        const res = await fetch(`${API}/blocked-columns/${colKey}`, {
            method: 'POST', 
            headers: {
                'RequestVerificationToken': TOKEN
            }
        });
        if (!res.ok) throw new Error();
        blockedCols = new Set(await res.json());
        document.querySelectorAll('#header-row th').forEach(th => {
            const k = th.dataset.key;
            if (!k || k === '__actions') return;
            th.classList.toggle('col-blocked', blockedCols.has(k));
            th.querySelector('.col-block-btn')?.classList.toggle('active', blockedCols.has(k));
        });
        renderTable();
        showAlert(`"${colKey}" ${blockedCols.has(colKey) ? 'kilidləndi 🔒' : 'açıldı 🔓'}`, 'info');
    } catch { showAlert('Xəta baş verdi.', 'danger'); }
}

