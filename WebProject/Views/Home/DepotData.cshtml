// ══════════════════════════════════════════════════════════════════════
//  OPTIONS MANAGER MODAL
// ══════════════════════════════════════════════════════════════════════

// Human-readable labels for each option key
const OPT_LABELS = {
    CDOptions: 'CD', QapiROptions: 'QapiR', SayKamOptions: 'SayKam',
    HDDVOptions: 'HDDV', HDDHOptions: 'HDDH', HDDSMOptions: 'HDDSM',
    DVRVOptions: 'DVRV', KamOptions: 'Kam', KamVOptions: 'KamV',
    KamNomOptions: 'KamNom', SalMonOptions: 'SalMon', DaySesOptions: 'DaySes',
    SurMikOptions: 'SurMik', TrafaredOptions: 'Trafared',
};

function openOptionsManager() {
    // Remove existing overlay if any
    document.getElementById('opt-overlay')?.remove();

    const overlay = document.createElement('div');
    overlay.className = 'opt-overlay';
    overlay.id = 'opt-overlay';
    overlay.onclick = e => { if (e.target === overlay) closeOptionsManager(); };

    const modal = document.createElement('div');
    modal.className = 'opt-modal';
    modal.innerHTML = `
        <div class="opt-modal-header">
            <h3>⚙ Seçim Siyahıları</h3>
            <button class="opt-modal-close" onclick="closeOptionsManager()">×</button>
        </div>
        <div class="opt-modal-body" id="opt-modal-body"></div>`;
    overlay.appendChild(modal);
    document.body.appendChild(overlay);
    renderOptionsModal();
}

function closeOptionsManager() {
    document.getElementById('opt-overlay')?.remove();
}

function renderOptionsModal() {
    const body = document.getElementById('opt-modal-body');
    if (!body) return;
    body.innerHTML = '';

    Object.entries(OPT_LABELS).forEach(([optKey, label]) => {
        const values = OPTIONS[optKey] || [];
        const group  = document.createElement('div');
        group.className = 'opt-group';
        group.id = `opt-group-${optKey}`;

        group.innerHTML = `
            <div class="opt-group-title">${label}</div>
            <div class="opt-items" id="opt-items-${optKey}">
                ${values.length === 0
                    ? `<span class="opt-empty">Seçim yoxdur</span>`
                    : values.map(v => optItemHtml(optKey, v)).join('')}
            </div>
            <div class="opt-add-row">
                <input id="opt-inp-${optKey}" type="text" placeholder="Yeni seçim…"
                       onkeydown="if(event.key==='Enter') addOption('${optKey}')">
                <button class="opt-add-btn" onclick="addOption('${optKey}')">+ Əlavə et</button>
            </div>`;
        body.appendChild(group);
    });
}

function optItemHtml(optKey, v) {
    return `<div class="opt-item">
        <span>${esc(v)}</span>
        <button class="opt-item-del" title="Sil" onclick="removeOption('${optKey}','${esc(v)}')">🗑</button>
    </div>`;
}

async function addOption(optKey) {
    const inp   = document.getElementById(`opt-inp-${optKey}`);
    const value = inp.value.trim();
    if (!value) return;

    try {
        const res = await fetch(`${API}/options/${optKey}`, {
            method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify(value)
        });
        if (!res.ok) throw new Error(await res.text());
        OPTIONS[optKey] = await res.json();
        inp.value = '';
        refreshOptItems(optKey);
        showAlert(`"${value}" əlavə edildi.`, 'success');
    } catch(e) { showAlert('Xəta: ' + e.message, 'danger'); }
}

async function removeOption(optKey, value) {
    if (!confirm(`"${value}" silinsin?`)) return;
    try {
        const res = await fetch(`${API}/options/${optKey}/${encodeURIComponent(value)}`, { method: 'DELETE' });
        if (!res.ok) throw new Error(await res.text());
        OPTIONS[optKey] = await res.json();
        refreshOptItems(optKey);
        showAlert(`"${value}" silindi.`, 'warning');
    } catch(e) { showAlert('Xəta: ' + e.message, 'danger'); }
}

function refreshOptItems(optKey) {
    const container = document.getElementById(`opt-items-${optKey}`);
    if (!container) return;
    const values = OPTIONS[optKey] || [];
    container.innerHTML = values.length === 0
        ? `<span class="opt-empty">Seçim yoxdur</span>`
        : values.map(v => optItemHtml(optKey, v)).join('');
}

// ══════════════════════════════════════════════════════════════════════
//  EXPORT
// ══════════════════════════════════════════════════════════════════════
async function exportFiltered() {
    const q = document.getElementById('global-search').value.toLowerCase();

    let rows = allData.filter(r => {
        if (q) {
            const txt = COLUMNS.map(c => String(r[c.key] ?? '')).join(' ').toLowerCase();
            if (!txt.includes(q)) return false;
        }
        for (const [k, v] of Object.entries(colFilters)) {
            if (!v) continue;
            if (k === 'isConfirmed') {
                if (v === 'true'  && !r.isConfirmed) return false;
                if (v === 'false' &&  r.isConfirmed) return false;
            } else if (v instanceof Set && v.size > 0) {
                if (!v.has(String(r[k] ?? ''))) return false;
            }
        }
        for (const col of COLUMNS.filter(c => c.dateFilter)) {
            const filters = dateFiltersMap[col.key];
            if (!filters || filters.length === 0) continue;
            const rowDate = r[col.key] ? String(r[col.key]).split('T')[0] : '';
            if (!filters.includes(rowDate)) return false;
        }
        return true;
    });

    if (rows.length === 0) { showAlert('Heç bir sıra tapılmadı.', 'warning'); return; }

    const res = await fetch(`${API}/export`, {
        method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
        body: JSON.stringify(rows)
    });
    if (!res.ok) { showAlert('Export xətası.', 'danger'); return; }

    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url;
    a.download = `DepotData_${new Date().toISOString().slice(0,10)}.xlsx`;
    a.click();
    URL.revokeObjectURL(url);
}

// ══════════════════════════════════════════════════════════════════════
//  CLEAR FILTERS
// ══════════════════════════════════════════════════════════════════════
function clearAllFilters() {
    colFilters     = {};
    dateFiltersMap = {};
    document.getElementById('global-search').value = '';
    document.querySelectorAll('.fdd-btn').forEach(btn => {
        btn.querySelector('.fdd-label').textContent = 'Hamısı';
        btn.classList.remove('has-filter');
    });
    document.querySelectorAll('.filter-row select').forEach(s => s.value = '');
    COLUMNS.filter(c => c.dateFilter).forEach(col => renderDateTags(col.key));
    renderTable();
}

// ══════════════════════════════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════════════════════════════
function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function showAlert(msg, type) {
    const el = document.getElementById('depot-alert');
    el.className = `depot-alert show ${type}`;
    el.textContent = msg;
    clearTimeout(el._t);
    el._t = setTimeout(() => el.classList.remove('show'), 3000);
}
