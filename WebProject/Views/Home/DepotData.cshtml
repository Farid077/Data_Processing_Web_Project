// ══════════════════════════════════════════════════════════════════════
//  PIN COLUMN
// ══════════════════════════════════════════════════════════════════════
function togglePinCol(colKey) {
    pinnedColKeys = pinnedColKeys.includes(colKey)
        ? pinnedColKeys.filter(k => k !== colKey)
        : [...pinnedColKeys, colKey];
    document.querySelectorAll('.col-pin-btn').forEach(btn =>
        btn.classList.toggle('active', pinnedColKeys.includes(btn.dataset.pinKey)));
    renderTable();
}

function applyColPinning() {
    // Clear all previous pin styles (also clear 'right' now)
    document.querySelectorAll('#depot-table .col-pinned').forEach(el => {
        el.classList.remove('col-pinned');
        el.style.removeProperty('position');
        el.style.removeProperty('left');
        el.style.removeProperty('right');
        el.style.removeProperty('z-index');
        el.style.removeProperty('background');
    });
    if (pinnedColKeys.length === 0) return;

    // Sort pinned cols by natural column position — not pinning order
    const pinnedByNaturalOrder = COLUMNS
        .map((col, idx) => ({ col, idx }))
        .filter(({ col }) => pinnedColKeys.includes(col.key));

    const midPoint = COLUMNS.length / 2;

    // Left-side: columns in first half → stick left
    const leftPinned  = pinnedByNaturalOrder
        .filter(({ idx }) => idx < midPoint)
        .sort((a, b) => a.idx - b.idx);

    // Right-side: columns in second half → stick right
    const rightPinned = pinnedByNaturalOrder
        .filter(({ idx }) => idx >= midPoint)
        .sort((a, b) => b.idx - a.idx); // reverse: rightmost first

    setTimeout(() => {
        // ── Left-side pins ──────────────────────────────────────
        let leftOffset = 0;
        leftPinned.forEach(({ col, idx }) => {
            const headerTh = document.querySelector(`#header-row th:nth-child(${idx + 1})`);
            if (!headerTh) return;
            const colWidth = headerTh.offsetWidth;

            document.querySelectorAll('#depot-table tr').forEach(tr => {
                const cell = tr.children[idx];
                if (!cell) return;
                cell.classList.add('col-pinned');
                cell.style.position   = 'sticky';
                cell.style.left       = leftOffset + 'px';
                cell.style.zIndex     = tr.closest('thead') ? '18' : '3';
                cell.style.background = 'var(--surface)';
            });
            leftOffset += colWidth;
        });

        // ── Right-side pins ─────────────────────────────────────
        // Start offset after the always-sticky Actions column
        const actTh = document.querySelector('#header-row th.col-sticky-right');
        let rightOffset = actTh ? actTh.offsetWidth : 0;

        rightPinned.forEach(({ col, idx }) => {
            const headerTh = document.querySelector(`#header-row th:nth-child(${idx + 1})`);
            if (!headerTh) return;
            const colWidth = headerTh.offsetWidth;

            document.querySelectorAll('#depot-table tr').forEach(tr => {
                const cell = tr.children[idx];
                if (!cell) return;
                cell.classList.add('col-pinned');
                cell.style.position   = 'sticky';
                cell.style.right      = rightOffset + 'px';
                cell.style.removeProperty('left');
                cell.style.zIndex     = tr.closest('thead') ? '18' : '3';
                cell.style.background = 'var(--surface)';
            });
            rightOffset += colWidth;
        });
    }, 0);
}

// ══════════════════════════════════════════════════════════════════════
//  IMPORT EXCEL FILE
// ══════════════════════════════════════════════════════════════════════
async function importExcel(input) {
    if (!input.files[0]) return;

    const formData = new FormData();
    formData.append('file', input.files[0]);

    showAlert('İdxal edilir…', 'info');

    try {
        const res = await fetch(`${API}/import?depot=@Model`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': TOKEN
            },
            body: formData   // do NOT set Content-Type — browser sets it with boundary
        });

        if (!res.ok) {
            const err = await res.text();
            showAlert(`İdxal xətası: ${err}`, 'danger');
            return;
        }

        const result = await res.json();
        showAlert(`${result.imported} sıra idxal edildi!`, 'success');
        await loadData();   // reload the table without refreshing the page
    } catch(e) {
        showAlert(`İdxal xətası: ${e.message}`, 'danger');
    }

    input.value = ''; // reset so same file can be re-imported if needed
}

