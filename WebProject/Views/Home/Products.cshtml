@{
    ViewData["Title"] = "Products";
    ViewData["ActivePage"] = "Product";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Products</h2>
        <button class="btn btn-primary" onclick="addNewRow()">+ New Row</button>
    </div>

    <div id="alert-area"></div>

    <table class="table table-bordered table-hover" id="products-table">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price ($)</th>
                <th>Stock</th>
                <th style="width:160px">Actions</th>
            </tr>
        </thead>
        <tbody id="table-body">
            <!-- rows injected by JS -->
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const API = '/api/products';

        // ─── Bootstrap ───────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', loadTable);

        // ─── Load all rows ────────────────────────────────────────────
        async function loadTable() {
            const res  = await fetch(API);
            const rows = await res.json();
            const tbody = document.getElementById('table-body');
            tbody.innerHTML = '';
            rows.forEach(r => tbody.appendChild(buildRow(r)));
        }

        // ─── Build a display row ──────────────────────────────────────
        function buildRow(p) {
            const tr = document.createElement('tr');
            tr.dataset.id = p.id;
            tr.innerHTML = `
                <td class="text-muted small align-middle">${p.id}</td>
                <td class="align-middle">${esc(p.name)}</td>
                <td class="align-middle">${esc(p.category)}</td>
                <td class="align-middle">${p.price.toFixed(2)}</td>
                <td class="align-middle">${p.stock}</td>
                <td style="display:flex;">
                    <button class="action-btn edit" style="text-decoration:none;" onclick="editRow(this)">Edit</button>
                    <button class="action-btn del"  onclick="deleteRow(${p.id}, this)">Delete</button>
                </td>`;
            return tr;
        }

        // ─── Switch row to edit mode ──────────────────────────────────
        function editRow(btn) {
            const tr = btn.closest('tr');
            const cells = tr.querySelectorAll('td');
            // cells[0] = ID (read-only), 1=name, 2=category, 3=price, 4=stock
            const fields = ['name','category','price','stock'];
            const types  = ['text','text','number','number'];

            [1,2,3,4].forEach((ci, fi) => {
                const val = cells[ci].innerText.trim();
                cells[ci].innerHTML =
                    `<input class="form-control form-control-sm" type="${types[fi]}"
                            name="${fields[fi]}" value="${esc(val)}" step="0.01">`;
            });

            cells[5].innerHTML = `
                <button class="action-btn edit" style="text-decoration:none;" onclick="saveRow(this)">Save</button>
                <button class="action-btn del" onclick="cancelRow(this)">Cancel</button>`;
        }

        // ─── Save edited row ──────────────────────────────────────────
        async function saveRow(btn) {
            const tr = btn.closest('tr');
            const id = parseInt(tr.dataset.id);
            const inputs = tr.querySelectorAll('input');
            const body = {
                id,
                name:     inputs[0].value.trim(),
                category: inputs[1].value.trim(),
                price:    parseFloat(inputs[2].value),
                stock:    parseInt(inputs[3].value)
            };
            if (!body.name) { showAlert('Name cannot be empty.', 'danger'); return; }

            try {
                const res = await fetch(`${API}/${id}`, {
                    method: 'PUT',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify(body)
                });
                if (!res.ok) throw new Error(await res.text());
                const updated = await res.json();
                tr.replaceWith(buildRow(updated));
                showAlert('Saved!', 'success');
            } catch(e) { showAlert('Save failed: ' + e.message, 'danger'); }
        }

        // ─── Cancel editing ───────────────────────────────────────────
        async function cancelRow(btn) {
            const tr = btn.closest('tr');
            const id = parseInt(tr.dataset.id);
            if (isNaN(id)) { tr.remove(); return; }   // was a new unsaved row
            const res = await fetch(`${API}/${id}`);   // re-fetch fresh data isn't needed; just reload
            loadTable();
        }

        // ─── Delete row ───────────────────────────────────────────────
        async function deleteRow(id, btn) {
            if (!confirm('Delete this row?')) return;
            try {
                const res = await fetch(`${API}/${id}`, { method: 'DELETE' });
                if (!res.ok) throw new Error();
                btn.closest('tr').remove();
                showAlert('Deleted.', 'warning');
            } catch { showAlert('Delete failed.', 'danger'); }
        }

        // ─── Add blank new row at top ─────────────────────────────────
        function addNewRow() {
            // Only one new row at a time
            if (document.querySelector('tr[data-id="new"]')) return;
            const tr = document.createElement('tr');
            tr.dataset.id = 'new';
            tr.innerHTML = `
                <td class="text-muted small align-middle"><em>new</em></td>
                <td><input class="form-control form-control-sm" name="name"     type="text"   placeholder="Name"></td>
                <td><input class="form-control form-control-sm" name="category" type="text"   placeholder="Category"></td>
                <td><input class="form-control form-control-sm" name="price"    type="number" placeholder="0.00" step="0.01" min="0"></td>
                <td><input class="form-control form-control-sm" name="stock"    type="number" placeholder="0"    min="0"></td>
                <td style="display:flex;">
                    <button class="action-btn edit" style="text-decoration:none;" onclick="createRow(this)">Create</button>
                    <button class="action-btn del" onclick="this.closest('tr').remove()">Cancel</button>
                </td>`;
            document.getElementById('table-body').prepend(tr);
            tr.querySelector('input[name="name"]').focus();
        }

        // ─── POST new row ─────────────────────────────────────────────
        async function createRow(btn) {
            const tr = btn.closest('tr');
            const inputs = tr.querySelectorAll('input');
            const body = {
                name:     inputs[0].value.trim(),
                category: inputs[1].value.trim(),
                price:    parseFloat(inputs[2].value) || 0,
                stock:    parseInt(inputs[3].value)   || 0
            };
            if (!body.name) { showAlert('Name is required.', 'danger'); inputs[0].focus(); return; }

            try {
                const res = await fetch(API, {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify(body)
                });
                if (!res.ok) throw new Error(await res.text());
                const created = await res.json();
                tr.replaceWith(buildRow(created));
                showAlert('Created!', 'success');
            } catch(e) { showAlert('Create failed: ' + e.message, 'danger'); }
        }

        // ─── Helpers ──────────────────────────────────────────────────
        function esc(s) {
            return String(s)
                .replace(/&/g,'&amp;').replace(/</g,'&lt;')
                .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function showAlert(msg, type) {
            const div = document.getElementById('alert-area');
            div.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show py-2" role="alert">
                ${msg}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            setTimeout(() => div.innerHTML = '', 3000);
        }
    </script>
}