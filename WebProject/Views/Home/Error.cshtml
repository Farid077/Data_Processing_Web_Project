@model ErrorVM
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div style="display:flex; flex-direction:column; align-items:center;
    justify-content:center; min-height:60vh; text-align:center; padding:40px;">

    <div style="font-size:64px; margin-bottom:24px;">⚠ Xəta</div>

    <h2 style="font-family:'Syne',sans-serif; font-size:28px; font-weight:800;
        letter-spacing:-.02em; margin-bottom:12px;">
        Gözlənilməz xəta baş verdi
    </h2>

    <p style="color:var(--text-dim); font-size:14px; max-width:480px;
        line-height:1.7; margin-bottom:32px;">
        @Model.ErrorMessage
    </p>

    @if (!string.IsNullOrEmpty(Model.RequestId))
    {
        <p style="font-size:11px; color:var(--muted); margin-bottom:32px;
            font-family:'DM Mono',monospace; letter-spacing:.06em;">
            Request ID: @Model.RequestId
        </p>
    }

    <div style="display:flex; gap:12px;">
        <button style="padding: 9px 24px;" onclick="history.back()" class="btn-accent">← Geri</button>
        <a href="/" class="btn-ghost" style="text-decoration:none;
            border-radius:6px; font-family:'DM Mono',monospace; font-size:13px;">
            Ana səhifə
        </a>
    </div>
</div>