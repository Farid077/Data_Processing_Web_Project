@model Role
@{
    ViewData["Title"] = $"Edit {Model.Name}";
    ViewData["ActivePage"] = "Roles";
}

<div style="padding: 20px; max-width: 900px; margin: 0 auto;">
    <div class="topbar">
        <h1 class="page-title">Rolu Redaktə Et: <span style="color: var(--accent);">@Model.Name</span></h1>
    </div>

    <form asp-action="Update" asp-route-id="@Model.Name" method="post">
        @Html.AntiForgeryToken()

        <div class="card">
            <div class="card-header">
                <h3 style="margin: 0; font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700;">Rol Məlumatları</h3>
            </div>
            <div class="form-body">
                <div class="field">
                    <label>Rol Adı</label>
                    <input type="text" value="@Model.Name" disabled style="background: var(--border); cursor: not-allowed;" />
                    <small style="color: var(--text-dim); font-size: 11px;">Rol adları dəyişdirilə bilməz</small>
                </div>
            </div>
        </div>

        <div class="card" style="margin-top: 24px;">
            <div class="card-header">
                <h3 style="margin: 0; font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700;">İcazələr</h3>
            </div>
            <div class="form-body">
                @{
                    var accessFlags = Enum.GetValues<PageAccess>()
                        // .Where(a => a != PageAccess.FullAccess)
                        .ToList();
                }

                @foreach (var page in Enum.GetValues<Pages>())
                {
                    var pageAccess = Model.Permissions.ContainsKey((byte)page) 
                        ? Model.Permissions[(byte)page] 
                        : 0;

                    <div style="background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 16px; margin-bottom: 12px;">
                        <div style="font-weight: 500; margin-bottom: 12px;">@(page)</div>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-left: 12px;">
                            @foreach (var access in accessFlags)
                            {
                                var isChecked = (pageAccess & (int)access) == (int)access;

                                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px;">
                                    <input type="checkbox" 
                           name="perms_@((int)page)_@((int)access)" 
                           value="1" 
                           @(isChecked ? "checked" : "") />
                                    @((PermissionsInAzerbaijani)((int)access))
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card-footer" style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px;">
            <a asp-action="Index" class="btn-cancel">Ləğv et</a>
            @if (User.HasAccess(Pages.Roles, PageAccess.Update)){
                <button type="submit" class="btn-save">Dəyişiklikləri Yadda Saxla</button>
            }
        </div>
    </form>
</div>