@model List<Role>
@{
    ViewData["Title"] = "Roles";
    ViewData["ActivePage"] = "Roles";
}

<div class="section-header">
    <div class="section-title">Roles Management</div>
    <div style="display: flex;">
        <div class="stat-label">Total Roles:</div>
        <div style="margin-left: 15px;" class="stat-label">@Model.Count()</div>
    </div>
    @if (User.HasAccess(Pages.Roles, PageAccess.Create)){
        <a asp-action="Create" class="btn-accent">+ Create Role</a>
    }
</div>

    @* @if (!Model.Any())
    {
        <div style="text-align: center; padding: 60px 20px; color: var(--text-dim);">
            <p style="font-size: 14px;">No roles yet. <a asp-action="Create" style="color: var(--accent);">Create one</a></p>
        </div>
    } *@
    @* else
    { *@
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th style="width: 15%;">Role Name</th>
                        <th style="width: 50%;">Permissions</th>
                        <th style="width: 20%;">Users</th>
                        <th style="width: 15%;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td style="font-weight: 500;">@role.Name</td>
                            <td>
                                @if (role.Permissions.Any(p => p.Value > 0))
                                {
                                    @foreach (var perm in role.Permissions.Where(p => p.Value > 0))
                                    {
                                        var page = (Pages)perm.Key;
                                        var access = (PageAccess)perm.Value;
                                        <div class="role-tag" style="margin-bottom: 4px;">
                                            @(page.ToString()) - @access.ToString()
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span style="color: var(--text-dim); font-size: 12px;">No permissions</span>
                                }
                            </td>
                            <td>
                                @if (role.Users.Any())
                                {
                                    <span style="font-size: 12px; color: var(--text-dim);">
                                        @string.Join(", ", role.Users.Select(u => u.Username))
                                    </span>
                                }
                                else
                                {
                                    <span style="color: var(--muted); font-size: 12px;">—</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    @if (User.HasAccess(Pages.Roles, PageAccess.Update))
                                    {
                                        if (role.Name != "SuperAdmin")
                                        {
                                            <a asp-action="Update" asp-route-id="@role.Name" class="action-btn edit">Edit</a>
                                        }
                                    }
                                    @if (User.HasAccess(Pages.Roles, PageAccess.Delete))
                                    {
                                        if (role.Name != "SuperAdmin" && role.Name != "User")
                                        {
                                            <form asp-action="Delete" asp-route-id="@role.Name" method="post" style="display: inline;"
                                            onsubmit="return confirm('Delete this role?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="action-btn del">Delete</button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    @* } *@
</div>
